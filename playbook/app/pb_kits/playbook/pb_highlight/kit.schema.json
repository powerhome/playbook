{
  "$schema": "https://playbook.powerapp.cloud/schemas/kit-schema.json",
  "name": "Highlight",
  "description": "Highlight is used to pick out or emphasize content.",
  "platforms": [
    "react",
    "rails"
  ],
  "props": {
    "text": {
      "type": "string",
      "platforms": [
        "react",
        "rails"
      ]
    },
    "highlightedText": {
      "type": "array",
      "platforms": [
        "react"
      ]
    }
  },
  "globalProps": true,
  "usage": {
    "react": {
      "import": "import { Highlight } from 'playbook-ui'",
      "example": "<Highlight></Highlight>"
    },
    "rails": {
      "import": null,
      "example": "<%= pb_rails(\"highlight\", props: { text: \"Example\" }) %>"
    }
  }
}
