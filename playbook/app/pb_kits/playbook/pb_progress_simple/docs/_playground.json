{
  "template": "<ProgressSimple{{props}} />",
  "propTargets": {},
  "defaults": {
    "align": "left",
    "muted": false,
    "variant": "default",
    "percent": "50",
    "width": "100%"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "percent",
        "value",
        "max"
      ]
    },
    {
      "name": "Behavior",
      "props": [
        "align"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "variant",
        "muted",
        "width",
        "dark"
      ]
    }
  ],
  "presets": [
    {
      "name": "0%",
      "props": {
        "percent": "0"
      }
    },
    {
      "name": "50%",
      "props": {
        "percent": "50"
      }
    },
    {
      "name": "100%",
      "props": {
        "percent": "100"
      }
    },
    {
      "name": "variant: positive",
      "props": {
        "percent": "75",
        "variant": "positive"
      }
    },
    {
      "name": "Muted",
      "props": {
        "muted": true,
        "percent": "50"
      }
    },
    {
      "name": "Value of Max",
      "props": {
        "value": 2,
        "max": 10
      }
    },
    {
      "name": "Fixed Width",
      "props": {
        "percent": "40",
        "width": "120px"
      }
    },
    {
      "name": "Centered",
      "props": {
        "percent": "60",
        "align": "center"
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "percent": {
      "when": {
        "percent": "50"
      },
      "message": "Percent accepts a number-like string and renders that width directly.",
      "type": "info"
    },
    "value_max": {
      "presetName": "Value of Max",
      "message": "Use value with max when the progress should be calculated from a ratio.",
      "type": "info"
    },
    "width": {
      "when": {
        "width": "120px"
      },
      "message": "Width controls the progress bar container; percent still controls the fill.",
      "type": "info"
    },
    "variant: positive": {
      "when": {
        "variant": "positive"
      },
      "message": "Use the variant prop to set the color of the progress bar.",
      "type": "info"
    }
  }
}
