{
  "$schema": "https://playbook.powerapp.cloud/schemas/kit-schema.json",
  "name": "IconValue",
  "description": "IconValue component",
  "platforms": [
    "react",
    "rails"
  ],
  "props": {
    "align": {
      "type": "enum",
      "platforms": [
        "react",
        "rails"
      ],
      "values": [
        "left",
        "center",
        "right"
      ],
      "default": "left"
    },
    "dark": {
      "type": "boolean",
      "platforms": [
        "react"
      ]
    },
    "icon": {
      "type": "string",
      "platforms": [
        "react",
        "rails"
      ]
    },
    "text": {
      "type": "string",
      "platforms": [
        "react",
        "rails"
      ]
    }
  },
  "globalProps": true,
  "usage": {
    "react": {
      "import": "import { IconValue } from 'playbook-ui'",
      "example": "<IconValue align=\"left\"></IconValue>"
    },
    "rails": {
      "import": null,
      "example": "<%= pb_rails(\"icon_value\", props: { align: \"left\" }) %>"
    }
  }
}
