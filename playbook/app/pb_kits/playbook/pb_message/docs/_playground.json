{
  "template": "<Message{{props}}>{{children}}</Message>",
  "propTargets": {},
  "defaults": {
    "avatarGrayscale": false,
    "timezone": "America/New_York",
    "alignTimestamp": "right"
  },
  "children": {
    "editable": true,
    "default": "Message content"
  },
  "groups": [
    {
      "name": "Props",
      "props": [
        "avatarGrayscale",
        "avatarName",
        "avatarStatus",
        "avatarUrl",
        "label",
        "message",
        "timestamp",
        "timestampObject",
        "timezone",
        "alignTimestamp"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {},
      "children": "Message content"
    }
  ],
  "conditionals": {},
  "hints": {}
}
