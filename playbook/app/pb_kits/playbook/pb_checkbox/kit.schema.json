    "indeterminateMain": {
      "platforms": [
        "rails"
      ],
      "type": "boolean",
      "default": false
    },
    "indeterminateMainLabels": {
      "platforms": [
        "rails"
      ],
      "type": "array"
    },
    "indeterminateParent": {
      "platforms": [
        "rails"
      ]
    },
    "inputOptions": {
      "platforms": [
        "rails"
      ],
      "type": "string"
    },
    "required": {
      "platforms": [
        "rails"
      ],
      "type": "boolean",
      "default": false
    },
    "formSpacing": {
      "platforms": [
        "rails"
      ],
      "type": "boolean",
      "default": false
    },
    "hiddenInput": {
      "platforms": [
        "rails"
      ],
      "type": "boolean",
      "default": false
    },
    "hiddenValue": {
      "platforms": [
        "rails"
      ]
    }
  },
  "globalProps": true,
  "usage": {
    "react": {
      "import": "import { Checkbox } from 'playbook-ui'",
      "example": "<Checkbox></Checkbox>"
    },
    "rails": {
      "import": null,
      "example": "<%= pb_rails(\"checkbox\", props: { text: \"Example\" }) %>"
    }
  }
}
