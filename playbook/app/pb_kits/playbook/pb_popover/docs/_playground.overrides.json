{
  "children": {
    "default": "Popover body"
  },
  "groups": [
    {
      "name": "Behavior",
      "props": [
        "placement",
        "show",
        "closeOnClick",
        "reference",
        "shouldClosePopover"
      ]
    },
    { "name": "Appearance", "props": ["offset", "appendTo"] }
  ],
  "presets": [
    {
      "name": "Open — top",
      "props": { "placement": "top", "show": true },
      "children": "Popover on top"
    },
    {
      "name": "Open — bottom",
      "props": { "placement": "bottom", "show": true },
      "children": "Popover on bottom"
    },
    {
      "name": "Open — left",
      "props": { "placement": "left", "show": true },
      "children": "Popover on the left"
    },
    {
      "name": "Open — right",
      "props": { "placement": "right", "show": true },
      "children": "Popover on the right"
    },
    {
      "name": "Closed",
      "props": { "placement": "bottom", "show": false },
      "children": "Trigger content"
    },
    {
      "name": "With offset",
      "props": { "placement": "bottom", "show": true, "offset": true },
      "children": "Extra spacing from the trigger"
    },
    {
      "name": "Close on outside click",
      "props": {
        "placement": "bottom",
        "show": true,
        "closeOnClick": "outside"
      },
      "children": "Click outside to dismiss"
    }
  ],
  "conditionals": {},
  "hints": {
    "show_popover": {
      "when": { "show": false },
      "message": "Set show to true in the playground to render the popover content.",
      "type": "info"
    }
  }
}
