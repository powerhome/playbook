{
  "structureModes": {
    "default": "standard",
    "modes": {
      "standard": {
        "label": "Standard",
        "template": "<MultiLevelSelect\n  id=\"multi-level-select-playground\"\n  treeData={treeData}{{props}}\n/>"
      },
      "with_children": {
        "label": "With Options Children",
        "template": "<MultiLevelSelect\n  id=\"multi-level-select-with-children-playground\"\n  treeData={treeData}{{props}}\n>\n  <MultiLevelSelect.Options>\n    {(item) => (\n      <Badge\n          marginLeft=\"sm\"\n          text={item.status || 'available'}\n          variant={item.status === 'active' ? 'success' : 'warning'}\n      />\n    )}\n  </MultiLevelSelect.Options>\n</MultiLevelSelect>"
      }
    }
  },
  "children": {
    "editable": false,
    "default": ""
  },
  "customProps": {
    "treeData": {
      "type": "array",
      "platforms": [
        "react",
        "rails"
      ],
      "description": "Nested option data with id, label, value, and optional children."
    }
  },
  "requiredProps": {
    "treeData": [
      {
        "label": "Power Home Remodeling",
        "value": "powerHomeRemodeling",
        "id": "powerhome1",
        "expanded": true,
        "status": "active",
        "children": [
          {
            "label": "People",
            "value": "people",
            "id": "people1",
            "expanded": true,
            "status": "active",
            "children": [
              {
                "label": "Talent Acquisition",
                "value": "talentAcquisition",
                "id": "talent1",
                "status": "active"
              },
              {
                "label": "Business Affairs",
                "value": "businessAffairs",
                "id": "business1",
                "status": "active",
                "children": [
                  {
                    "label": "Initiatives",
                    "value": "initiatives",
                    "id": "initiative1",
                    "status": "active"
                  },
                  {
                    "label": "Learning & Development",
                    "value": "learningAndDevelopment",
                    "id": "development1",
                    "status": "inactive"
                  }
                ]
              },
              {
                "label": "People Experience",
                "value": "peopleExperience",
                "id": "experience1",
                "status": "inactive"
              }
            ]
          },
          {
            "label": "Contact Center",
            "value": "contactCenter",
            "id": "contact1",
            "status": "inactive",
            "children": [
              {
                "label": "Appointment Management",
                "value": "appointmentManagement",
                "id": "appointment1",
                "status": "active"
              },
              {
                "label": "Customer Service",
                "value": "customerService",
                "id": "customer1",
                "status": "inactive"
              },
              {
                "label": "Energy",
                "value": "energy",
                "id": "energy1",
                "status": "active"
              }
            ]
          }
        ]
      }
    ]
  },
  "defaults": {
    "disabled": false,
    "error": "",
    "inputDisplay": "pills",
    "inputName": "",
    "label": "",
    "required": false,
    "requiredIndicator": false,
    "returnAllSelected": false,
    "showCheckedChildren": true,
    "placeholder": "Start typing...",
    "variant": "multi",
    "wrapped": false,
    "selectedIds": [
      "talent1",
      "initiative1"
    ],
    "onSelect": "(selectedNodes) => console.log('Selected Items', selectedNodes)",
    "onChange": "(event) => console.log('Filter changed', event.target.value)"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "treeData",
        "label",
        "name",
        "placeholder",
        "selectedIds",
        "inputName"
      ]
    },
    {
      "name": "State",
      "props": [
        "disabled",
        "error",
        "required",
        "requiredIndicator"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "inputDisplay",
        "variant",
        "wrapped"
      ]
    },
    {
      "name": "Selection Behavior",
      "props": [
        "returnAllSelected",
        "showCheckedChildren"
      ]
    },
    {
      "name": "Events",
      "props": [
        "onSelect",
        "onChange"
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi",
      "structureMode": "standard",
      "props": {
        "variant": "multi",
        "label": "Departments",
        "placeholder": "Search teams...",
        "inputDisplay": "pills",
        "onSelect": "(selectedNodes) => console.log('Selected Items', selectedNodes)"
      }
    },
    {
      "name": "Single Select",
      "structureMode": "standard",
      "props": {
        "variant": "single",
        "label": "Pick one team",
        "placeholder": "Choose...",
        "inputDisplay": "pills",
        "selectedIds": [
          "talent1"
        ],
        "onSelect": "(selectedNode) => console.log('Selected Node', selectedNode)"
      }
    },
    {
      "name": "Selected IDs",
      "structureMode": "standard",
      "props": {
        "variant": "multi",
        "label": "Preselected teams",
        "selectedIds": [
          "talent1",
          "initiative1",
          "customer1"
        ],
        "onSelect": "(selectedNodes) => console.log('Selected Items', selectedNodes)"
      }
    },
    {
