{
  "defaults": {
    "treeData": [
      {
        "label": "Company",
        "value": "company",
        "id": "mls_co",
        "expanded": true,
        "children": [
          {
            "label": "Engineering",
            "value": "engineering",
            "id": "mls_eng",
            "children": [
              {
                "label": "Frontend",
                "value": "frontend",
                "id": "mls_fe"
              },
              {
                "label": "Backend",
                "value": "backend",
                "id": "mls_be"
              }
            ]
          },
          {
            "label": "Sales",
            "value": "sales",
            "id": "mls_sales"
          }
        ]
      }
    ]
  },
  "groups": [
    {
      "name": "Content",
      "props": ["label", "name", "placeholder", "treeData", "selectedIds"]
    },
    {
      "name": "State",
      "props": ["disabled", "error", "required", "requiredIndicator"]
    },
    {
      "name": "Appearance",
      "props": ["inputDisplay", "variant", "wrapped"]
    },
    {
      "name": "Selection behavior",
      "props": ["returnAllSelected", "showCheckedChildren", "inputName"]
    },
    {
      "name": "Events",
      "props": ["onChange", "onSelect"]
    }
  ],
  "presets": [
    {
      "name": "Multi (default)",
      "props": {
        "variant": "multi",
        "label": "Departments",
        "placeholder": "Search teams…",
        "inputDisplay": "pills"
      }
    },
    {
      "name": "Single select",
      "props": {
        "variant": "single",
        "label": "Pick one team",
        "placeholder": "Choose…",
        "inputDisplay": "pills"
      }
    },
    {
      "name": "Plain input (no pills)",
      "props": {
        "variant": "multi",
        "label": "Teams",
        "inputDisplay": "none"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "variant": "multi",
        "label": "Locked",
        "disabled": true
      }
    },
    {
      "name": "With error",
      "props": {
        "variant": "multi",
        "label": "Required field",
        "error": "Choose at least one option."
      }
    },
    {
      "name": "Return all selected",
      "props": {
        "variant": "multi",
        "label": "Include ancestors",
        "returnAllSelected": true
      }
    },
    {
      "name": "Hide checked in tree",
      "props": {
        "variant": "multi",
        "label": "Compact tree",
        "showCheckedChildren": false
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "tree_data": {
      "when": {},
      "message": "treeData is a nested list with id, label, value, and optional children; expand with expanded on nodes you want open by default.",
      "type": "info"
    }
  }
}
