{
  "template": "<Icon{{props}} />",
  "propTargets": {},
  "defaults": {
    "fixedWidth": true,
    "inverse": false,
    "listItem": false,
    "pulse": false,
    "fontStyle": "far",
    "spin": false,
    "icon": "user"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "icon"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "size",
        "color",
        "fixedWidth"
      ]
    },
    {
      "name": "Transform",
      "props": [
        "flip",
        "rotation",
        "spin",
        "pulse",
        "pull",
        "border",
        "inverse",
        "listItem",
        "tabIndex"
      ]
    }
  ],
  "presets": [
    {
      "name": "Regular User",
      "props": {
        "icon": "user",
        "fixedWidth": true
      }
    },
    {
      "name": "Primary Check",
      "props": {
        "icon": "check",
        "color": "primary",
        "fixedWidth": true
      }
    },
    {
      "name": "Product Icon",
      "props": {
        "icon": "product-roofing",
        "color": "product_5_background",
        "fixedWidth": true
      }
    },
    {
      "name": "Small Search",
      "props": {
        "icon": "search",
        "size": "sm",
        "fixedWidth": true
      }
    },
    {
      "name": "Spinning",
      "props": {
        "icon": "sync",
        "spin": true,
        "fixedWidth": true
      }
    },
    {
      "name": "Pulse Spinner",
      "props": {
        "icon": "spinner",
        "pulse": true,
        "size": "2x",
        "fixedWidth": true
      }
    },
    {
      "name": "Bordered Pull",
      "props": {
        "icon": "arrow-left",
        "border": true,
        "pull": "left",
        "fixedWidth": true
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "regular_user": {
      "presetName": "Regular User",
      "message": "Use any icon form Playbook Icons by passing the icon name to the icon prop.",
      "type": "info"
    },
    "product_icon": {
      "presetName": "Product Icon",
      "message": "Use any product icon by passing the icon name to the icon prop.",
      "type": "info"
    },
    "spinning": {
      "presetName": "Spinning",
      "message": "spin applies the continuous spinning animation.",
      "type": "info"
    },
    "pulse_spinner": {
      "presetName": "Pulse Spinner",
      "message": "pulse uses the stepped pulse animation, which is commonly paired with spinning icons.",
      "type": "info"
    },
    "primary_check": {
      "presetName": "Primary Check",
      "message": "Use the color prop to change the color of the icon.",
      "type": "info"
    },
    "small_search": {
      "presetName": "Small Search",
      "message": "Use the size prop to change the size of the icon.",
      "type": "info"
    }
  },
  "hiddenProps": [
    "customIcon",
    "fontStyle",
    "border"
  ]
}
