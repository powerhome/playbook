{
  "template": "<div onClick={handleWrapperClick}>\n  <SelectableIcon checked={isChecked} onChange={handleChange}{{props}} />\n</div>",
  "propTargets": {},
  "defaults": {
    "checked": false,
    "disabled": false,
    "inputs": "enabled",
    "multi": true,
    "icon": "user",
    "inputId": "assignee_1",
    "name": "assignee",
    "text": "Assignee",
    "value": "user1"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "icon",
        "text",
        "name",
        "value",
        "inputId"
      ]
    },
    {
      "name": "State",
      "props": [
        "checked",
        "disabled",
        "multi",
        "inputs"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "dark"
      ]
    }
  ],
  "presets": [
    {
      "name": "Unchecked",
      "props": {
        "icon": "user",
        "text": "Assignee",
        "name": "assignee",
        "inputId": "assignee_1",
        "value": "user1",
        "checked": false,
        "multi": true,
        "inputs": "enabled"
      }
    },
    {
      "name": "Checked",
      "props": {
        "icon": "check-circle",
        "text": "Confirmed",
        "name": "status",
        "inputId": "status_1",
        "value": "ok",
        "checked": true,
        "multi": true,
        "inputs": "enabled"
      }
    },
    {
      "name": "Radio (single)",
      "props": {
        "icon": "circle",
        "text": "Option A",
        "name": "radio_demo",
        "inputId": "radio_a",
        "value": "a",
        "checked": true,
        "multi": false,
        "inputs": "enabled"
      }
    },
    {
      "name": "Inputs hidden",
      "props": {
        "icon": "star",
        "text": "Favorite",
        "name": "fav",
        "inputId": "fav_1",
        "value": "fav",
        "checked": false,
        "inputs": "disabled",
        "multi": true
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "unchecked": {
      "presetName": "Unchecked",
      "message": "Unchecked shows the default selectable icon with a visible checkbox input and state-backed preview toggling.",
      "type": "info"
    },
    "checked": {
      "presetName": "Checked",
      "message": "Checked applies the selected visual state while keeping inputs enabled.",
      "type": "info"
    },
    "radio": {
      "presetName": "Radio (single)",
      "message": "Radio (single) sets multi to false so the rendered input is a radio.",
      "type": "info"
    },
    "inputs_hidden": {
      "presetName": "Inputs hidden",
      "message": "Inputs hidden renders without a visible form input; the playground wrapper still toggles the preview state when clicked.",
      "type": "info"
    }
  },
  "wrapper": "const SelectableIconPlayground = () => {\n  const [isChecked, setIsChecked] = useState(checked)\n  const handleChange = ({ target }) => setIsChecked(target.checked)\n  const handleWrapperClick = ({ target }) => {\n    if (target.closest('input, label')) return\n    setIsChecked((current) => !current)\n  }\n\n  return {{component}}\n}\n\n<SelectableIconPlayground />",
  "externalImports": [
    "import React, { useState } from 'react'"
  ],
  "statefulProps": [
    "checked"
  ],
  "hiddenProps": [
    "customIcon"
  ]
}
