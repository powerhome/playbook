  "hints": {
    "vertical": {
      "presetName": "Vertical",
      "message": "Vertical Nav uses editable NavItem children and can include a title link above the item list.",
      "type": "info"
    },
    "horizontal": {
      "presetName": "Horizontal",
      "message": "Horizontal Nav keeps the same NavItem children but changes layout with orientation=\"horizontal\".",
      "type": "info"
    },
    "subtle": {
      "presetName": "Subtle",
      "message": "variant=\"subtle\" changes the Nav visual treatment while Nav passes orientation and variant down to each NavItem.",
      "type": "info"
    },
    "borderless": {
      "presetName": "Borderless",
      "message": "borderless removes item borders from the Nav list.",
      "type": "info"
    },
    "no_highlight": {
      "presetName": "No Highlight",
      "message": "highlight={false} removes the active item highlight styling.",
      "type": "info"
    },
    "extended_underline": {
      "presetName": "Extended Underline",
      "message": "extendedUnderline applies only when orientation=\"horizontal\" and variant=\"normal\".",
      "type": "info"
    },
    "nav_item_icons": {
      "presetName": "NavItem Icons",
      "message": "NavItem iconLeft and iconRight add icons around the item text.",
      "type": "info"
    },
    "nav_item_disabled": {
      "presetName": "NavItem Disabled",
      "message": "disabled makes the NavItem non-interactive and removes link navigation.",
      "type": "info"
    },
    "nav_item_typography": {
      "presetName": "NavItem Typography",
      "message": "NavItem fontSize and fontWeight control item label styling.",
      "type": "info"
    },
    "nav_item_spacing": {
      "presetName": "NavItem Spacing",
      "message": "NavItem spacing props can tighten or expand individual item layout.",
      "type": "info"
    },
    "collapsible": {
      "presetName": "Collapsible",
      "message": "collapsible turns a NavItem into a parent item with nested NavItems inside Collapsible.Content.",
      "type": "info"
    },
    "collapsible_trail": {
      "presetName": "Collapsible Trail",
      "message": "collapsibleTrail adds the nested trail styling for collapsible Nav groups.",
      "type": "info"
    }
  }
}
