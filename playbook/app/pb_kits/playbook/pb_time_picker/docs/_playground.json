{
  "template": "<TimePicker{{props}} />",
  "propTargets": {},
  "defaults": {
    "disabled": false,
    "label": "Time Picker",
    "required": false,
    "requiredIndicator": false,
    "showTimezone": false,
    "timeFormat": "AMPM",
    "validationMessage": ""
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "name",
        "defaultTime"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "timeFormat",
        "showTimezone",
        "dark"
      ]
    },
    {
      "name": "Validation",
      "props": [
        "required",
        "requiredIndicator",
        "disabled",
        "minTime",
        "maxTime",
        "error",
        "validationMessage"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "label": "Start time",
        "name": "start_time",
        "defaultTime": "3:30 PM"
      }
    },
    {
      "name": "24-hour",
      "props": {
        "label": "Duration start",
        "name": "duration_start",
        "timeFormat": "24hour",
        "defaultTime": "15:30"
      }
    },
    {
      "name": "With timezone",
      "props": {
        "label": "Meeting time",
        "name": "meeting_time",
        "defaultTime": "9:00 AM",
        "showTimezone": true
      }
    },
    {
      "name": "Business hours",
      "props": {
        "label": "Callback window",
        "name": "callback_time",
        "minTime": "9:00 AM",
        "maxTime": "5:00 PM",
        "defaultTime": "2:00 PM"
      }
    },
    {
      "name": "Required Field",
      "props": {
        "label": "Appointment",
        "name": "appointment_time",
        "required": true,
        "requiredIndicator": true,
        "defaultTime": "10:00 AM"
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default uses defaultTime so the picker initializes with a value while remaining internally editable.",
      "type": "info"
    },
    "twenty_four_hour": {
      "presetName": "24-hour",
      "message": "24-hour switches timeFormat to the 24hour display and input pattern.",
      "type": "info"
    },
    "with_timezone": {
      "presetName": "With timezone",
      "message": "With timezone shows the timezone label next to the selected time.",
      "type": "info"
    },
    "business_hours": {
      "presetName": "Business hours",
      "message": "Business hours combines minTime and maxTime to constrain available selections.",
      "type": "info"
    },
    "required_field": {
      "presetName": "Required Field",
      "message": "Required Field combines required and requiredIndicator for validation-ready forms.",
      "type": "info"
    }
  },
  "hiddenProps": [
    "inputOptions",
    "onChange",
    "onClose",
    "value"
  ]
}
