{
  "template": "<Avatar{{props}} />",
  "propTargets": {},
  "defaults": {
    "grayscale": false,
    "imageAlt": "",
    "name": "",
    "size": "md"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "name",
        "imageUrl",
        "imageAlt"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "size",
        "grayscale",
        "status"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "size": "md",
        "name": "Jane Doe",
        "imageUrl": "https://randomuser.me/api/portraits/women/44.jpg"
      }
    },
    {
      "name": "Small",
      "props": {
        "size": "sm",
        "name": "Alex Kim",
        "imageUrl": "https://randomuser.me/api/portraits/men/32.jpg"
      }
    },
    {
      "name": "Initials only",
      "props": {
        "size": "md",
        "name": "Jordan Lee"
      }
    },
    {
      "name": "Online status",
      "props": {
        "size": "md",
        "name": "Jordan Lee",
        "imageUrl": "https://randomuser.me/api/portraits/men/32.jpg",
        "status": "online"
      }
    },
    {
      "name": "Status + Small",
      "props": {
        "size": "sm",
        "name": "Jordan Lee",
        "imageUrl": "https://randomuser.me/api/portraits/men/32.jpg",
        "status": "away"
      }
    },
    {
      "name": "Initials + online",
      "props": {
        "size": "md",
        "name": "Morgan Blake",
        "status": "online"
      }
    },
    {
      "name": "Grayscale photo",
      "props": {
        "size": "md",
        "name": "Photo user",
        "imageUrl": "https://randomuser.me/api/portraits/women/68.jpg",
        "grayscale": true
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "status_indicator": {
      "when": {
        "status": "online"
      },
      "message": "Status shows a dot when name or image is set; it does not appear when using component overlay mode.",
      "type": "info"
    },
    "image_fallback": {
      "when": {
        "imageUrl": "https://unsplash.it/200/200"
      },
      "message": "If the image fails to load, initials from name are shown instead.",
      "type": "info"
    }
  }
}
