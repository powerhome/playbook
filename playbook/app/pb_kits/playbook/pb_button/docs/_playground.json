{
  "template": "<Button{{props}}>{{children}}</Button>",
  "propTargets": {},
  "defaults": {
    "variant": "primary"
  },
  "children": {
    "editable": true,
    "default": "Click Me",
    "hideWhenPropSet": ["text"]
  },
  "conditionals": {
    "count": {
      "requires": { "variant": "reaction" }
    },
    "highlight": {
      "requires": { "variant": "reaction" }
    },
    "iconRight": {
      "requires": "icon"
    },
    "target": {
      "requires": "link"
    },
    "newWindow": {
      "requires": "link"
    }
  },
  "groups": [
    {
      "name": "Appearance",
      "props": ["variant", "size", "fullWidth", "disabled", "loading"]
    },
    {
      "name": "Content",
      "props": ["text", "icon", "iconRight"]
    },
    {
      "name": "Link Mode",
      "props": ["link", "target", "newWindow"]
    },
    {
      "name": "Reaction Mode",
      "props": ["count", "highlight"]
    },
    {
      "name": "Form",
      "props": ["htmlType", "form", "value", "tabIndex"]
    }
  ],
  "presets": [
    {
      "name": "Primary",
      "props": { "variant": "primary" },
      "children": "Submit"
    },
    {
      "name": "Secondary",
      "props": { "variant": "secondary" },
      "children": "Cancel"
    },
    {
      "name": "Danger",
      "props": { "variant": "danger" },
      "children": "Delete"
    },
    {
      "name": "With Icon",
      "props": { "icon": "plus", "variant": "primary" },
      "children": "Add Item"
    },
    {
      "name": "Loading",
      "props": { "loading": true, "variant": "primary" },
      "children": "Saving..."
    },
    {
      "name": "Reaction",
      "props": { "variant": "reaction", "icon": "👍", "count": 5 },
      "children": ""
    },
    {
      "name": "Link",
      "props": { "variant": "link" },
      "children": "Learn More"
    }
  ],
  "hints": {
    "reaction_needs_icon": {
      "when": { "variant": "reaction" },
      "message": "Reaction buttons display an icon (emoji or icon name). If no icon is set, a default smiley will be shown.",
      "type": "info"
    },
    "link_mode_info": {
      "when": { "link": true },
      "message": "When link is set, the button renders as an <a> tag instead of <button>.",
      "type": "info"
    },
    "loading_hides_content": {
      "when": { "loading": true },
      "message": "Loading state shows a spinner and hides the button content.",
      "type": "info"
    }
  }
}
