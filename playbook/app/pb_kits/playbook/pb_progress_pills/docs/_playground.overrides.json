{
  "defaults": {
    "active": 2,
    "fullWidthPill": false,
    "steps": 4,
    "title": "Checkout",
    "value": "Payment"
  },
  "groups": [
    { "name": "Content", "props": ["title", "value"] },
    { "name": "Behavior", "props": ["steps", "active"] },
    { "name": "Appearance", "props": ["fullWidthPill", "dark"] }
  ],
  "presets": [
    {
      "name": "Step 1 of 4",
      "props": { "steps": 4, "active": 1, "title": "Checkout", "value": "Shipping" }
    },
    {
      "name": "Step 2 of 4",
      "props": { "steps": 4, "active": 2, "title": "Checkout", "value": "Payment" }
    },
    {
      "name": "Complete",
      "props": {
        "steps": 4,
        "active": 4,
        "title": "Checkout",
        "value": "Review"
      }
    },
    {
      "name": "Not started",
      "props": {
        "steps": 4,
        "active": 0,
        "title": "Progress",
        "value": "No steps completed yet"
      }
    },
    {
      "name": "Full-width pills",
      "props": {
        "steps": 3,
        "active": 2,
        "fullWidthPill": true,
        "title": "Wide layout",
        "value": "Pills stretch to fill the row"
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "status": {
      "when": { "title": "Checkout" },
      "message": "Title and value add the status label above the pill row.",
      "type": "info"
    },
    "full_width": {
      "when": { "fullWidthPill": true },
      "message": "Full-width pills stretch each segment across the available row.",
      "type": "info"
    },
    "active_range": {
      "message": "Active is zero-based for an empty state and counts completed pills up to the steps total.",
      "type": "info"
    }
  }
}
