{
  "template": "<Tooltip{{props}}>{{children}}</Tooltip>",
  "propTargets": {},
  "defaults": {
    "useClickToOpen": false,
    "interaction": false
  },
  "children": {
    "editable": true,
    "default": "Hover me",
    "hideWhenPropSet": []
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "text",
        "icon"
      ]
    },
    {
      "name": "Behavior",
      "props": [
        "placement",
        "useClickToOpen",
        "interaction",
        "delay"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "showTooltip",
        "forceOpenTooltip",
        "position"
      ]
    },
    {
      "name": "Sizing",
      "props": [
        "width",
        "minWidth",
        "maxWidth",
        "height",
        "minHeight",
        "maxHeight"
      ]
    }
  ],
  "presets": [
    {
      "name": "Top",
      "props": {
        "placement": "top",
        "text": "Tooltip on top"
      },
      "children": "Hover me"
    },
    {
      "name": "With Icon",
      "props": {
        "icon": "info-circle",
        "placement": "right",
        "text": "Tooltip with an icon"
      },
      "children": "Hover me"
    },
    {
      "name": "Click to Open",
      "props": {
        "placement": "top",
        "useClickToOpen": true,
        "text": "Click toggles this tooltip"
      },
      "children": "Click me"
    },
    {
      "name": "Forced Open",
      "props": {
        "forceOpenTooltip": true,
        "placement": "bottom",
        "text": "Forced open for demos"
      },
      "children": "Always visible"
    }
  ],
  "conditionals": {},
  "hints": {
    "top": {
      "presetName": "Top",
      "message": "Top uses the default hover behavior with the tooltip above the trigger.",
      "type": "info"
    },
    "with_icon": {
      "presetName": "With Icon",
      "message": "With Icon adds an icon inside the tooltip content.",
      "type": "info"
    },
    "click_to_open": {
      "presetName": "Click to Open",
      "message": "When click to open is on, the tooltip toggles on click instead of hover.",
      "type": "info"
    },
    "forced_open": {
      "presetName": "Forced Open",
      "message": "Forced Open keeps the tooltip visible, which is useful for demos and visual checks.",
      "type": "info"
    }
  }
}
