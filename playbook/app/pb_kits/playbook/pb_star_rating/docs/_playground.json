{
  "template": "<StarRating{{props}} />",
  "propTargets": {},
  "defaults": {
    "layoutOption": "default",
    "rating": 4,
    "denominator": 5,
    "colorOption": "yellow",
    "backgroundType": "fill",
    "size": "sm",
    "variant": "display"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "icon"
      ]
    },
    {
      "name": "Rating",
      "props": [
        "rating",
        "denominator",
        "variant"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "layoutOption",
        "colorOption",
        "backgroundType",
        "size",
        "fixedWidth"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "rating": 4,
        "denominator": 5,
        "variant": "display"
      }
    },
    {
      "name": "Number layout",
      "props": {
        "rating": 4.2,
        "denominator": 5,
        "layoutOption": "number",
        "variant": "display",
        "size": "md"
      }
    },
    {
      "name": "One star highlight",
      "props": {
        "rating": 1,
        "denominator": 5,
        "layoutOption": "onestar",
        "variant": "display"
      }
    },
    {
      "name": "Interactive",
      "props": {
        "rating": 0,
        "denominator": 5,
        "variant": "interactive"
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default shows the common five-star display rating.",
      "type": "info"
    },
    "number": {
      "presetName": "Number layout",
      "message": "Number layout displays the numeric rating beside the stars.",
      "type": "info"
    },
    "one_star": {
      "presetName": "One star highlight",
      "message": "One star highlight uses the compact one-star layout for summary scores.",
      "type": "info"
    },
    "interactive": {
      "presetName": "Interactive",
      "message": "Interactive mode is ready for a click handler in product code; the playground keeps it visual.",
      "type": "info"
    }
  },
  "hiddenProps": [
    "onClick"
  ]
}
