<%= pb_rails("button", props: { text: "Open dialog (inputs overflow)", data: { open_dialog: "dialog-inputs-overflow" } }) %>

<%= pb_rails("dialog", props: {
  id: "dialog-inputs-overflow",
  size: "lg",
}) do %>
  <%= pb_rails("dialog/dialog_header", props: { id: "dialog-inputs-overflow" }) do %>
    <%= pb_rails("body", props: { text: "Form inside dialog" }) %>
  <% end %>
  <%= pb_rails("dialog/dialog_body") do %>
    <%= pb_rails("flex", props: { orientation: "row", gap: "md" }) do %>
      <%= pb_rails("typeahead", props: {
        label: "Typeahead",
        options: typeahead_options,
        placeholder: "Search country…",
        id: "inputs-overflow-typeahead-1",
        is_multi: false,
        margin_bottom: "none",
      }) %>
      <%= pb_rails("dropdown", props: {
        id: "inputs-overflow-dialog-dropdown-rails",
        label: "Dropdown",
        options: typeahead_options,
        placeholder: "Select a country…",
        margin_bottom: "none",
      }) %>
      <%= pb_rails("multi_level_select", props: {
        id: "inputs-overflow-dialog-mls-rails",
        label: "Multi Level Select",
        tree_data: tree_data_inputs_overflow,
        margin_bottom: "none",
      }) %>
      <%= pb_rails("date_picker", props: {
        label: "Date Picker",
        name: "inputs_overflow_dialog_start",
        picker_id: "inputs-overflow-dialog-start-rails",
        min_date: "01/01/2000",
        max_date: "12/31/2030",
        margin_bottom: "none",
        }) %>
      <%= pb_rails("time_picker", props: {
        label: "Time Picker",
        name: "inputs_overflow_dialog_time",
        id: "inputs-overflow-dialog-time-rails",
        margin_bottom: "none",
      }) %>
    <% end %>
  <% end %>
  <%= pb_rails("dialog/dialog_footer", props: {
    cancel_button: "Cancel",
    confirm_button: "Save",
    confirm_button_id: "confirm-inputs-overflow",
    id: "dialog-inputs-overflow",
  }) %>
<% end %>
