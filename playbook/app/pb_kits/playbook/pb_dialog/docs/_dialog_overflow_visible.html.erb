<%= pb_rails("flex", props: { orientation: "row", gap: "lg", wrap: true, align: "start" }) do %>
  <%= pb_rails("button", props: { text: "Open Dialog with Overflow Visible", data: { open_dialog: "dialog-overflow-visible" } }) %>
  <%= pb_rails("flex", props: { orientation: "column", gap: "md" }) do %>
    <%= pb_rails("body", props: {
      color: "light",
      text: "Filter popovers (same setups as the Table Filter Card building block) sit on the doc page. Open the dialog to test Typeahead in the dialog body.",
    }) %>
    <%= pb_rails("caption", props: { text: "FILTER #1 HAS NO MAX HEIGHT" }) %>
    <%=
      pb_rails("filter", props: {
        background: false,
        min_width: "xs",
        allow_overflow: true,
        popover_props: {
          width: "350px",
        },
        id: "overflow-visible-filter-rails-1",
        sort_menu: [
          { item: "Start Date", link: "?q[sorts]=started_on+asc", active: true, direction: "asc" },
          { item: "Title", link: "?q[sorts]=title+asc", active: false },
          { item: "Department", link: "?q[sorts]=department+asc", active: false },
          { item: "Branch", link: "?q[sorts]=branch+asc", active: false },
        ],
        template: "default",
        results: 50,
      }) do
    %>
      <%= pb_rails("multi_level_select", props: {
        id: "overflow-visible-mls-rails-1",
        name: "filter_region_office_1[]",
        label: "Multi Level Select",
        margin_bottom: "none",
        placeholder: "Search offices…",
        input_display: "none",
        tree_data: overflow_filter_mls_tree,
      }) %>
      <%= pb_rails("dropdown", props: {
        id: "overflow-visible-branch-rails-1",
        label: "Dropdown",
        margin_bottom: "none",
        options: overflow_filter_branch_options,
      }) %>
      <%= pb_rails("typeahead", props: {
        id: "overflow-visible-title-rails-1",
        is_multi: false,
        label: "Typeahead",
        margin_bottom: "none",
        options: overflow_filter_title_options,
        placeholder: "Search title…",
      }) %>
      <%= pb_rails("date_picker", props: {
        label: "Date Picker",
        margin_bottom: "none",
        picker_id: "overflow-visible-started-on-rails-1",
      }) %>
      <%= pb_rails("time_picker", props: {
        id: "overflow-visible-shift-time-rails-1",
        label: "Time Picker",
        margin_bottom: "none",
      }) %>
      <%= pb_rails("flex", props: { spacing: "between" }) do %>
        <%= pb_rails("button", props: { text: "Filter" }) %>
        <%= pb_rails("button", props: { text: "Defaults", variant: "secondary" }) %>
      <% end %>
    <% end %>
    <%= pb_rails("section_separator") %>
    <%= pb_rails("caption", props: { text: "FILTER #2 HAS MAX HEIGHT" }) %>
    <%=
      pb_rails("filter", props: {
        background: false,
        max_height: "50vh",
        min_width: "xs",
        allow_overflow: true,
        popover_props: {
          width: "350px",
        },
        id: "overflow-visible-filter-rails-2",
        sort_menu: [
          { item: "Start Date", link: "?q[sorts]=started_on+asc", active: true, direction: "asc" },
          { item: "Title", link: "?q[sorts]=title+asc", active: false },
          { item: "Department", link: "?q[sorts]=department+asc", active: false },
          { item: "Branch", link: "?q[sorts]=branch+asc", active: false },
        ],
        template: "default",
        results: 50,
      }) do
    %>
      <%= pb_rails("multi_level_select", props: {
        id: "overflow-visible-mls-rails-2",
        name: "filter_region_office_2[]",
        label: "Multi Level Select",
        placeholder: "Search offices…",
        input_display: "none",
        margin_bottom: "none",
        tree_data: overflow_filter_mls_tree,
      }) %>
      <%= pb_rails("dropdown", props: {
        id: "overflow-visible-branch-rails-2",
        label: "Dropdown",
        margin_bottom: "none",
        options: overflow_filter_branch_options,
      }) %>
      <%= pb_rails("typeahead", props: {
        id: "overflow-visible-title-rails-2",
        is_multi: false,
        label: "Typeahead",
        margin_bottom: "none",
        options: overflow_filter_title_options,
        placeholder: "Search title…",
      }) %>
      <%= pb_rails("date_picker", props: {
        label: "Date Picker",
        margin_bottom: "none",
        picker_id: "overflow-visible-started-on-rails-2",
      }) %>
      <%= pb_rails("time_picker", props: {
        id: "overflow-visible-shift-time-rails-2",
        label: "Time Picker",
        margin_bottom: "none",
      }) %>
      <%= pb_rails("flex", props: { spacing: "between" }) do %>
        <%= pb_rails("button", props: { text: "Filter" }) %>
        <%= pb_rails("button", props: { text: "Defaults", variant: "secondary" }) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= pb_rails("dialog", props: {
  id: "dialog-overflow-visible",
  size: "md",
}) do %>
  <%= pb_rails("dialog/dialog_header", props: { id: "dialog-overflow-visible" }) do %>
    <%= pb_rails("body", props: { text: "Select Location" }) %>
  <% end %>
  <%= pb_rails("dialog/dialog_body") do %>
    <%= pb_rails("typeahead", props: {
      options: typeahead_options,
      placeholder: "Select a location...",
      id: "location-typeahead",
      is_multi: false,
    }) %>
  <% end %>
  <%= pb_rails("dialog/dialog_footer", props: {
    cancel_button: "Cancel",
    confirm_button: "Save",
    confirm_button_id: "confirm-overflow-visible",
    id: "dialog-overflow-visible",
  }) %>
<% end %>
