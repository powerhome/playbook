{
  "template": "<FormattedDate{{props}} />",
  "groups": [
    {
      "name": "Date Config",
      "props": ["value", "showDayOfWeek", "showCurrentYear", "showIcon"]
    },
    {
      "name": "Appearance",
      "props": ["size", "alignment", "unstyled"]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "value": "2026-04-09"
      }
    },
    {
      "name": "centered",
      "props": {
        "value": "2026-04-09",
        "alignment": "center"
      }
    },
    {
      "name": "Small with weekday",
      "props": {
        "value": "2026-06-18",
        "size": "sm",
        "showDayOfWeek": true
      }
    },
    {
      "name": "With icon & year",
      "props": {
        "value": "2024-11-02",
        "showIcon": true,
        "showCurrentYear": true
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "default": {
      "message": "Use as FormattedDate to avoid naming collisions with global Date object",
      "type": "info"
    }
  }
}
