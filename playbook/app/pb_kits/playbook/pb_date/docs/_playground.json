{
  "template": "<Date{{props}} />",
  "propTargets": {},
  "defaults": {
    "alignment": "left",
    "showDayOfWeek": false,
    "showCurrentYear": false,
    "showIcon": false,
    "size": "md",
    "unstyled": false
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "value",
        "showDayOfWeek",
        "showCurrentYear",
        "showIcon"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "size",
        "alignment",
        "unstyled"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "value": "2026-04-09T15:30:00.000Z"
      }
    },
    {
      "name": "Large & centered",
      "props": {
        "value": "2026-04-09T15:30:00.000Z",
        "size": "lg",
        "alignment": "center"
      }
    },
    {
      "name": "Small with weekday",
      "props": {
        "value": "2026-06-18T10:00:00.000Z",
        "size": "sm",
        "showDayOfWeek": true
      }
    },
    {
      "name": "With icon & year",
      "props": {
        "value": "2024-11-02T09:00:00.000Z",
        "showIcon": true,
        "showCurrentYear": true
      }
    },
    {
      "name": "Unstyled",
      "props": {
        "value": "2026-04-09T15:30:00.000Z",
        "unstyled": true,
        "showDayOfWeek": true
      }
    }
  ],
  "conditionals": {},
  "hints": {}
}
