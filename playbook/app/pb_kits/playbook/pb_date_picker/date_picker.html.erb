<% date_picker_root_attrs = {
  class: object.classname + object.error_class,
  'data-pb-date-picker' => true,
  'data-validation-message' => object.validation_message,
}
  date_picker_root_attrs['data-default-value'] = object.serialized_default_date_for_dom if object.serialized_default_date_for_dom.present?
%>
<%= pb_content_tag(:div, date_picker_root_attrs) do %>
  <div class="input_wrapper">
    <% if !object.hide_label && object.label %>
      <label for="<%= object.picker_id %>">
        <% if object.required_indicator %>
          <%= pb_rails("caption", props: { dark: object.dark, classname: "pb_date_picker_kit_label", color: "lighter" }) do %>
            <%= object.label %><span style="color: #DA0014;"> *</span>
          <% end %>
        <% else %>
          <%= pb_rails("caption", props: { text: object.label, dark: object.dark, classname: "pb_date_picker_kit_label", color: "lighter" }) %>
        <% end %>
      </label>
    <% end %>
    <% if content.present? %>
      <%= content %>
    <% else %>
    <%= pb_rails("text_input", props: {
      aria: object.input_aria,
      autocomplete: false,
      cursor: object.cursor,
      dark: object.dark,
      data: object.input_data,
      disabled: object.disable_input,
      error: object.error,
      id: object.picker_id,
      margin_bottom: "none",
      name: object.name,
      placeholder: object.placeholder,
      required: object.required,
      validation: object.validation_message.present? ? { message: object.validation_message } : {},
    }) %>
    <% end %>
    <% if object.selection_type == "quickpick" %>
      <input type="hidden" id="<%= "#{object.start_date_id}" %>" name="<%= "#{object.start_date_name}" %>">
      <input type="hidden" id="<%= "#{object.end_date_id}" %>" name="<%= "#{object.end_date_name}" %>">
    <% end %>

    <% if !object.hide_icon && !object.inline %>
      <div
          class="<%= object.icon_wrapper_class %>"
          id="cal-icon-<%= object.picker_id %>"
      >
        <%= pb_rails("icon", props: {
          classname: "cal_icon",
          icon: "calendar-alt"
        }) %>
      </div>
    <% end %>

    <!-- Inline -->
    <% if object.inline %>
      <!-- Plus Icon -->
      <div
          class="<%= object.icon_wrapper_class %> date-picker-inline-icon-plus"
          id="<%= object.picker_id %>-icon-plus"
      >
        <%= pb_rails("icon", props: {
          classname: "plus-icon",
          icon: "plus"
        }) %>
      </div>

      <!-- Angle Down Icon -->
      <div
          class="<%= object.icon_wrapper_class %> date-picker-inline-angle-down"
          id="<%= object.picker_id %>-angle-down"
      >
        <%= pb_rails("icon", props: {
          classname: "angle_down_icon",
          custom_icon: Playbook::Engine::root.join(angle_down_path)
        }) %>
      </div>
    <% end %>
  </div>

  <%= javascript_tag do %>
    (function() {
      const initQuickPickChangeListener = (input) => {
        if (!<%= object.selection_type == "quickpick" %>) return
        if (input.dataset.quickpickInitialized) return

        input.dataset.quickpickInitialized = "true"
        input.addEventListener("change", ({ target }) => {
          const startDate = document.getElementById("<%= object.start_date_id %>")
          const endDate = document.getElementById("<%= object.end_date_id %>")
          const splittedValue = target.value.split(" to ")
          startDate.value = splittedValue[0]
          endDate.value = splittedValue[1] ? splittedValue[1] : splittedValue[0]
        })
      }

      const disconnectPopoverWatch = (input) => {
        if (!input) return

        if (input._pbDatePickerPopoverObserver) {
          input._pbDatePickerPopoverObserver.disconnect()
          delete input._pbDatePickerPopoverObserver
        }

        delete input.dataset.pbDatePickerPopoverWatch
      }

      const loadDatePicker = () => {
        const input = document.getElementById("<%= object.picker_id %>")

        if (!input || input._flatpickr) {
          disconnectPopoverWatch(input)
          return true
        }
        if (typeof window.datePickerHelper !== "function") return false

        const popoverTooltip = input.closest(".pb_popover_tooltip")
        if (popoverTooltip && !popoverTooltip.classList.contains("show")) {
          return false
        }

        window.datePickerHelper(<%= object.date_picker_config %>, "<%= object.scroll_container %>")
        initQuickPickChangeListener(input)
        disconnectPopoverWatch(input)

        return true
      }

      const watchPopoverVisibility = () => {
        const input = document.getElementById("<%= object.picker_id %>")
        if (!input || input.dataset.pbDatePickerPopoverWatch) return

        const popoverTooltip = input.closest(".pb_popover_tooltip")
        if (!popoverTooltip) return

        input.dataset.pbDatePickerPopoverWatch = "true"
        const tryInitWhenVisible = () => {
          if (!input.isConnected || !popoverTooltip.isConnected) {
            disconnectPopoverWatch(input)
            return
          }

          if (popoverTooltip.classList.contains("show")) {
            loadDatePicker()
          }
        }

        const observer = new MutationObserver(tryInitWhenVisible)
        input._pbDatePickerPopoverObserver = observer
        observer.observe(popoverTooltip, { attributes: true, attributeFilter: ["class"] })
        tryInitWhenVisible()
      }

      let attempts = 0
      const retryLoad = () => {
        if (loadDatePicker()) return

        const input = document.getElementById("<%= object.picker_id %>")
        if (input?.closest(".pb_popover_tooltip")) {
          watchPopoverVisibility()
          return
        }

        if (attempts++ < 20) {
          setTimeout(retryLoad, 100)
        }
      }

      if (document.readyState === "loading") {
        window.addEventListener("DOMContentLoaded", retryLoad)
      } else {
        retryLoad()
      }

      // For dynamically added content (modals, etc.), check again after a brief delay
      setTimeout(() => {
        const input = document.getElementById("<%= object.picker_id %>")
        if (input && !input._flatpickr) {
          retryLoad()
        }
      }, 100)

      if (<%= !object.custom_event_type.empty? %>) {
        window.addEventListener("<%= object.custom_event_type %>", retryLoad)
      }

      document.addEventListener("turbo:before-cache", () => {
        const input = document.getElementById("<%= object.picker_id %>")
        disconnectPopoverWatch(input)
        input?._flatpickr?.destroy()
      })
    })()
  <% end %>
<% end %>
