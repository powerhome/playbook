{
  "template": "<DatePicker {{props}} />",
  "propTargets": {},
  "defaults": {
    "allowInput": false,
    "defaultDate": "",
    "disableInput": false,
    "enableTime": false,
    "format": "m/d/Y",
    "hideIcon": false,
    "hideLabel": false,
    "label": "Date Picker",
    "placeholder": "Select Date",
    "requiredIndicator": false,
    "selectionType": "none",
    "showTimezone": false,
    "staticPosition": true,
    "thisRangesEndToday": false,
    "controlsStartId": "",
    "controlsEndId": "",
    "syncStartWith": "",
    "syncEndWith": "",
    "customQuickPickDates": {
      "override": false,
      "dates": []
    },
    "pickerId": "playground-date-picker",
    "disableDate": [],
    "disableRange": [],
    "disableWeekdays": [],
    "yearRange": [
      1900,
      2100
    ]
  },
  "groups": [
    {
      "name": "Date Picker Config",
      "props": [
        "label",
        "placeholder",
        "name",
        "pickerId",
        "defaultDate",
        "format"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "dark",
        "hideIcon",
        "hideLabel",
        "inLine"
      ]
    },
    {
      "name": "Quick pick",
      "props": [
        "selectionType",
        "customQuickPickDates",
        "thisRangesEndToday"
      ]
    },
    {
      "name": "Behavior",
      "props": [
        "allowInput",
        "enableTime",
        "showTimezone",
        "disableInput",
        "initializeOnce"
      ]
    },
    {
      "name": "Validation & bounds",
      "props": [
        "minDate",
        "maxDate",
        "yearRange",
        "disableDate",
        "disableWeekdays",
        "disableRange",
        "error",
        "requiredIndicator"
      ]
    },
    {
      "name": "Advanced",
      "props": [
        "inputValue",
        "inputOnChange",
        "inputAria",
        "inputData",
        "type",
        "timeFormat"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "name": "event_date",
        "pickerId": "playground-date-picker",
        "label": "Event date",
        "placeholder": "Select date"
      }
    },
    {
      "name": "Inline",
      "props": {
        "name": "inline_date",
        "pickerId": "playground-date-inline",
        "label": "Inline",
        "className": "inline-date-picker",
        "inLine": true,
        "hideIcon": true
      }
    },
    {
      "name": "Quick pick",
      "props": {
        "name": "quickpick_range",
        "pickerId": "playground-quickpick",
        "label": "Date range",
        "placeholder": "mm/dd/yyyy to mm/dd/yyyy",
        "allowInput": true,
        "selectionType": "quickpick"
      }
    },
    {
      "name": "Quick pick with Custom Dates",
      "props": {
        "name": "quickpick_range",
        "pickerId": "playground-quickpick",
        "label": "Date range",
        "placeholder": "mm/dd/yyyy to mm/dd/yyyy",
        "allowInput": true,
        "selectionType": "quickpick",
        "customQuickPickDates": {
          "override": false,
          "dates": [
            {
              "label": "Last 15 months",
              "value": {
                "timePeriod": "months",
                "amount": 15
              }
            },
            {
              "label": "First week of June 2022",
              "value": [
                "06/01/2022",
                "06/07/2022"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Date & time",
      "props": {
        "name": "starts_at",
        "pickerId": "playground-datetime",
        "label": "Starts at",
        "enableTime": true,
        "format": "m/d/Y H:i"
      }
    },
    {
      "name": "Allow typing",
      "props": {
        "name": "typed_date",
        "pickerId": "playground-allow-input",
        "label": "Start date",
        "allowInput": true
      }
    },
    {
      "name": "Month picker",
      "props": {
        "name": "month_only",
        "pickerId": "playground-month",
        "label": "Month",
        "selectionType": "month"
      }
    },
    {
      "name": "Week picker",
      "props": {
        "name": "week_only",
        "pickerId": "playground-week",
        "label": "Week",
        "selectionType": "week"
      }
    },
    {
      "name": "Dark",
      "props": {
        "name": "dark_picker",
        "pickerId": "playground-dark",
        "label": "Event date",
        "dark": true
      }
    },
    {
      "name": "Min / max range",
      "props": {
        "name": "bounded",
        "pickerId": "playground-bounded",
        "label": "Within range",
        "minDate": "01/01/2026",
        "maxDate": "12/31/2026"
      }
    },
    {
      "name": "Error state",
      "props": {
        "name": "invalid_date",
        "pickerId": "playground-error",
        "label": "Due date",
        "error": "Please choose a valid date"
      }
    }
  ],
  "conditionals": {
    "customQuickPickDates": {
      "requires": {
        "selectionType": "quickpick"
      }
    },
    "thisRangesEndToday": {
      "requires": {
        "selectionType": "quickpick"
      }
    }
  },
  "hints": {
    "pickerId": {
      "message": "The pickerId is used to identify the date picker in the DOM. It is required and must be unique.",
      "type": "info"
    },
    "defaultDate": {
      "when": {
        "defaultDate": "04/09/2026"
      },
      "message": "The default date is the date that will be selected when the date picker is first rendered. It is required and must be a valid date.",
      "type": "info"
    },
    "quickPick": {
      "when": {
        "selectionType": "quickpick"
      },
      "message": "Quick pick shows preset ranges (relative periods or explicit date pairs). Use thisRangesEndToday when the plugin should treat ranges as ending today.",
      "type": "info"
    },
    "customQuickPickDates": {
      "presetName": "Quick pick with Custom Dates",
      "message": "Custom quick pick dates are used to override the default quick pick dates. It must be an object with a dates array.",
      "type": "info"
    }
  },
  "hiddenProps": [
    "staticPosition",
    "scrollContainer",
    "controlsStartId",
    "controlsEndId",
    "syncStartWith",
    "syncEndWith",
    "positionElement"
  ]
}
