{
  "template": "<DatePicker {{props}} />",
  "propTargets": {},
  "defaults": {
    "allowInput": false,
    "defaultDate": "",
    "disableInput": false,
    "enableTime": false,
    "format": "m/d/Y",
    "hideIcon": false,
    "hideLabel": false,
    "label": "Date Picker",
    "placeholder": "Select Date",
    "requiredIndicator": false,
    "selectionType": "none",
    "showTimezone": false,
    "staticPosition": true,
    "thisRangesEndToday": false,
    "controlsStartId": "",
    "controlsEndId": "",
    "syncStartWith": "",
    "syncEndWith": "",
    "customQuickPickDates": {
      "override": false,
      "dates": []
    },
    "pickerId": "playground-date-picker",
    "disableDate": [],
    "disableRange": [],
    "disableWeekdays": [],
    "yearRange": [
      1900,
      2100
    ]
  },
  "groups": [
    {
      "name": "Date Picker Config",
      "props": [
        "label",
        "placeholder",
        "name",
        "pickerId",
        "defaultDate",
        "format"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "dark",
        "hideIcon",
        "hideLabel",
        "inLine",
        "selectionType"
      ]
    },
    {
      "name": "Behavior",
      "props": [
        "allowInput",
        "enableTime",
        "showTimezone",
        "disableInput",
        "initializeOnce"
      ]
    },
    {
      "name": "Validation & bounds",
      "props": [
        "minDate",
        "maxDate",
        "yearRange",
        "disableDate",
        "disableWeekdays",
        "disableRange",
        "error",
        "requiredIndicator"
      ]
    },
    {
      "name": "Advanced",
      "props": [
        "customQuickPickDates",
        "positionElement",
        "inputValue",
        "inputOnChange",
        "inputAria",
        "inputData",
        "type",
        "timeFormat",
        "thisRangesEndToday",
        "controlsStartId",
        "controlsEndId",
        "syncStartWith",
        "syncEndWith"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "name": "event_date",
        "pickerId": "playground-date-picker",
        "label": "Event date",
        "placeholder": "Select date"
      }
    },
    {
      "name": "Inline",
      "props": {
        "pickerId": "playground-date-inline",
        "label": "Inline",
        "inLine": true,
        "hideIcon": true
      }
    },
    {
      "name": "Date & time",
      "props": {
        "name": "starts_at",
        "pickerId": "playground-datetime",
        "label": "Starts at",
        "defaultDate": "04/09/2026",
        "enableTime": true,
        "format": "m/d/Y H:i"
      }
    },
    {
      "name": "Allow typing",
      "props": {
        "name": "typed_date",
        "pickerId": "playground-allow-input",
        "label": "Start date",
        "allowInput": true,
        "defaultDate": "04/09/2026"
      }
    },
    {
      "name": "Month picker",
      "props": {
        "name": "month_only",
        "pickerId": "playground-month",
        "label": "Month",
        "selectionType": "month",
        "defaultDate": "04/01/2026"
      }
    },
    {
      "name": "Week picker",
      "props": {
        "name": "week_only",
        "pickerId": "playground-week",
        "label": "Week",
        "selectionType": "week",
        "defaultDate": "04/09/2026"
      }
    },
    {
      "name": "Dark",
      "props": {
        "name": "dark_picker",
        "pickerId": "playground-dark",
        "label": "Event date",
        "defaultDate": "04/09/2026",
        "dark": true
      }
    },
    {
      "name": "Min / max range",
      "props": {
        "name": "bounded",
        "pickerId": "playground-bounded",
        "label": "Within range",
        "defaultDate": "04/09/2026",
        "minDate": "01/01/2026",
        "maxDate": "12/31/2026"
      }
    },
    {
      "name": "Error state",
      "props": {
        "name": "invalid_date",
        "pickerId": "playground-error",
        "label": "Due date",
        "error": "Please choose a valid date",
        "defaultDate": ""
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "pickerId": {
      "message": "The pickerId is used to identify the date picker in the DOM. It is required and must be unique.",
      "type": "info"
    },
    "defaultDate": {
      "when": {
        "defaultDate": "04/09/2026"
      },
      "message": "The default date is the date that will be selected when the date picker is first rendered. It is required and must be a valid date.",
      "type": "info"
    }
  },
  "hiddenProps": [
    "staticPosition",
    "scrollContainer"
  ]
}
