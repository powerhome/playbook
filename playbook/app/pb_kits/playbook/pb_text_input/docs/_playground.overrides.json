{
  "groups": [
    {
      "name": "Content",
      "props": ["label", "name", "placeholder", "value"]
    },
    {
      "name": "State",
      "props": ["disabled", "error", "required", "requiredIndicator"]
    },
    {
      "name": "Appearance",
      "props": ["inline", "type", "mask", "emojiMask", "autoComplete"]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "label": "Email",
        "name": "email",
        "placeholder": "you@example.com",
        "value": ""
      }
    },
    {
      "name": "With Error",
      "props": {
        "label": "Email",
        "name": "email",
        "placeholder": "you@example.com",
        "value": "not-an-email",
        "error": "Please enter a valid email address."
      }
    },
    {
      "name": "Disabled",
      "props": {
        "label": "First Name",
        "name": "first_name",
        "placeholder": "Jane",
        "value": "",
        "disabled": true
      }
    },
    {
      "name": "Required",
      "props": {
        "label": "Email",
        "name": "email",
        "placeholder": "you@example.com",
        "value": "",
        "required": true,
        "requiredIndicator": true
      }
    }
  ],
  "conditionals": {
    "requiredIndicator": { "requires": "label" }
  },
  "hints": {}
}
