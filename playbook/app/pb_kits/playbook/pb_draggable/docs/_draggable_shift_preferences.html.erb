<% on_at_five_items = [
  { id: "on-1", day: "Monday" },
  { id: "on-2", day: "Wednesday" },
  { id: "on-3", day: "Thursday" },
] %>

<% early_day_items = [
  { id: "early-1", day: "Monday" },
  { id: "early-2", day: "Wednesday" },
  { id: "early-3", day: "Thursday" },
] %>

<%= pb_rails("background", props: { background_color: "white", padding: "md", border_radius: "md" }) do %>
  <%= pb_rails("flex", props: { align: "start", justify: "between", margin_bottom: "md", wrap: true }) do %>
    <%= pb_rails("flex/flex_item") do %>
      <%= pb_rails("title", props: { size: 3, tag: "h2", text: "Schedule Preferences for Q3 2025" }) %>
      <%= pb_rails("caption", props: { margin_top: "xs", text: "Remodeling Consultant" }) %>
    <% end %>
    <%= pb_rails("background", props: { background_color: "neutral_subtle", border_radius: "sm", padding: "sm" }) do %>
      <%= pb_rails("caption", props: { size: "xs", text: "Due Date" }) %>
      <%= pb_rails("body", props: { text: "Thu - Jun 26" }) %>
    <% end %>
  <% end %>

  <%= pb_rails("background", props: { background_color: "neutral_subtle", border_radius: "sm", margin_bottom: "md", padding: "sm" }) do %>
    <%= pb_rails("caption", props: { text: "Camp Day and Tuesday are excluded from these preferences." }) %>
  <% end %>

  <%= pb_rails("title", props: { margin_bottom: "sm", size: 4, tag: "h3", text: "Shift Preferences" }) %>

  <%= pb_rails("flex", props: { gap: "lg", wrap: true }) do %>
    <%= pb_rails("flex/flex_item", props: { flex: 1 }) do %>
      <%= pb_rails("flex", props: { align: "center", gap: "xs", margin_bottom: "sm" }) do %>
        <%= pb_rails("toggle", props: { checked: true }) %>
        <%= pb_rails("title", props: { size: 4, tag: "h4", text: "On at 5 (5p - 8p)" }) %>
      <% end %>

      <%= pb_rails("draggable", props: { initial_items: on_at_five_items, drop_zone_type: "line" }) do %>
        <%= pb_rails("draggable/draggable_container", props: { drop_zone_direction: "vertical", html_options: { style: { min_height: "260px" } } }) do %>
          <% on_at_five_items.each_with_index do |item, index| %>
            <%= pb_rails("card", props: {
              drag_id: item[:id],
              draggable_item: true,
              highlight: { position: "side", color: "primary" },
              margin_bottom: "xs",
              padding: "sm",
            }) do %>
              <%= pb_rails("flex", props: { align: "center", gap: "sm", justify: "center" }) do %>
                <%= pb_rails("body", props: { color: "light", text: (index + 1).to_s }) %>
                <%= pb_rails("title", props: { size: 4, tag: "span", text: item[:day], text_align: "center" }) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%= pb_rails("flex/flex_item", props: { flex: 1 }) do %>
      <%= pb_rails("flex", props: { align: "center", gap: "xs", margin_bottom: "sm" }) do %>
        <%= pb_rails("toggle", props: { checked: true }) %>
        <%= pb_rails("title", props: { size: 4, tag: "h4", text: "Early Day (10a - 1:30p)" }) %>
      <% end %>

      <%= pb_rails("draggable", props: { initial_items: early_day_items, drop_zone_type: "line" }) do %>
        <%= pb_rails("draggable/draggable_container", props: { drop_zone_direction: "vertical", html_options: { style: { min_height: "260px" } } }) do %>
          <% early_day_items.each_with_index do |item, index| %>
            <%= pb_rails("card", props: {
              drag_id: item[:id],
              draggable_item: true,
              highlight: { position: "side", color: "primary" },
              margin_bottom: "xs",
              padding: "sm",
            }) do %>
              <%= pb_rails("flex", props: { align: "center", gap: "sm", justify: "center" }) do %>
                <%= pb_rails("body", props: { color: "light", text: (index + 1).to_s }) %>
                <%= pb_rails("title", props: { size: 4, tag: "span", text: item[:day], text_align: "center" }) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= pb_rails("flex", props: { align: "center", justify: "between", margin_top: "lg", wrap: true }) do %>
    <%= pb_rails("checkbox", props: { text: "Request Full Weekday Off" }) %>
    <%= pb_rails("button", props: { text: "Save Shift Preferences", variant: "primary" }) %>
  <% end %>
<% end %>

<%= pb_rails("caption", props: {
  margin_top: "sm",
  text: "Tip: Use a mobile viewport or device simulator. Drag from the grip to reorder; swipe the card body to scroll.",
}) %>