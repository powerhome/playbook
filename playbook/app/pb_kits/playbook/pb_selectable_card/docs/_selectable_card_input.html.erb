<%= pb_rails("title", props: { text: "PLAY-2880 CSB temporary doc example" }) %>

<%= pb_rails("caption", props: { margin_y: "sm", text: "Input Variant Checkbox Examples - Light Mode" }) %>

<%= pb_rails("selectable_card", props: {
  checked: true,
  disabled: true,
  input_id: "firstCheckbox",
  name: "firstCheckbox",
  value: "firstCheckbox",
  variant: "display_input",
}) do %>
  <%= pb_rails("body", props: { text: "Disabled + checked" }) %>
<% end %>

