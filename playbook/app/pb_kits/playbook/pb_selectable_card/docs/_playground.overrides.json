{
  "structureModes": {
    "default": "normal",
    "modes": {
      "normal": {
        "label": "Normal",
        "template": "<SelectableCard{{props}} />",
        "children": ""
      },
      "nested": {
        "label": "Nested",
        "template": "<SelectableCard{{props}}>\n  {{children}}\n</SelectableCard>",
        "children": "<Title size={4} text=\"Pro plan\" />\n<Body color=\"light\" text=\"Includes advanced reporting.\" />"
      }
    }
  },
  "children": {
    "editable": true,
    "default": "<Title size={4} text=\"Pro plan\" />\n<Body color=\"light\" text=\"Includes advanced reporting.\" />"
  },
  "defaults": {
    "checked": false,
    "disabled": false,
    "error": false,
    "icon": false,
    "inputId": "selectable_card_plan",
    "multi": true,
    "name": "selectable_card_demo",
    "text": "Standard plan",
    "value": "standard",
    "variant": "default"
  },
  "hiddenProps": ["customIcon", "onChange"],
  "groups": [
    {
      "name": "Content",
      "props": ["text", "value", "name", "inputId"]
    },
    {
      "name": "State",
      "props": ["checked", "disabled", "error", "multi"]
    },
    {
      "name": "Appearance",
      "props": ["variant", "icon", "dark"]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "structureMode": "normal",
      "props": {
        "checked": false,
        "inputId": "plan_standard",
        "name": "selectable_card_demo",
        "text": "Standard plan",
        "value": "standard",
        "multi": true,
        "variant": "default"
      }
    },
    {
      "name": "Nested Content",
      "structureMode": "nested",
      "props": {
        "checked": true,
        "icon": true,
        "inputId": "plan_pro",
        "name": "selectable_card_demo",
        "value": "pro",
        "multi": true,
        "variant": "default"
      },
      "children": "<Title size={4} text=\"Pro plan\" />\n<Body color=\"light\" text=\"Includes advanced reporting.\" />"
    },
    {
      "name": "Input Variant",
      "structureMode": "nested",
      "props": {
        "checked": true,
        "inputId": "plan_display",
        "name": "selectable_card_demo",
        "value": "display",
        "variant": "displayInput"
      },
      "children": "<Body text=\"Display input style\" />"
    }
  ],
  "conditionals": {},
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default renders a checkbox-style selectable card with simple text content.",
      "type": "info"
    },
    "nested_content": {
      "presetName": "Nested Content",
      "message": "Nested Content uses child JSX inside SelectableCard for richer card content.",
      "type": "info"
    },
    "radio": {
      "presetName": "Radio (single)",
      "message": "Radio (single) sets multi to false so the card behaves like a radio option.",
      "type": "info"
    },
    "input_variant": {
      "presetName": "Input Variant",
      "message": "Input Variant uses the displayInput treatment with nested content beside the visible input.",
      "type": "info"
    }
  }
}
