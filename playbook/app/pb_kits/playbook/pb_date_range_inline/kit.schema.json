{
  "$schema": "https://playbook.powerapp.cloud/schemas/kit-schema.json",
  "name": "DateRangeInline",
  "description": "Use to display a date range. Year will not show if it is the current",
  "platforms": [
    "react",
    "rails"
  ],
  "props": {
    "align": {
      "type": "\"left\" | \"center\" | \"right\";",
      "platforms": [
        "react",
        "rails"
      ],
      "values": [
        "left",
        "center",
        "right"
      ],
      "default": "left"
    },
    "endDate": {
      "type": "Date;",
      "platforms": [
        "react",
        "rails"
      ]
    },
    "icon": {
      "type": "boolean;",
      "platforms": [
        "react",
        "rails"
      ]
    },
    "size": {
      "type": "\"sm\" | \"xs\";",
      "platforms": [
        "react",
        "rails"
      ],
      "values": [
        "xs",
        "sm"
      ],
      "default": "sm"
    },
    "showCurrentYear": {
      "type": "boolean;",
      "platforms": [
        "react",
        "rails"
      ],
      "default": false
    },
    "startDate": {
      "type": "Date;",
      "platforms": [
        "react",
        "rails"
      ]
    }
  },
  "globalProps": true,
  "usage": {
    "react": {
      "import": "import { DateRangeInline } from 'playbook-ui'",
      "example": "<DateRangeInline align=\"left\" size=\"xs\"></DateRangeInline>"
    },
    "rails": {
      "import": null,
      "example": "<%= pb_rails(\"date_range_inline\", props: { align: \"left\", size: \"xs\" }) %>"
    }
  }
}
