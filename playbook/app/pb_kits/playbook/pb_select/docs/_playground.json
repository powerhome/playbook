{
  "template": "<Select{{props}} />",
  "propTargets": {},
  "defaults": {
    "compact": false,
    "disabled": false,
    "inline": false,
    "multiple": false,
    "required": false,
    "requiredIndicator": false,
    "showArrow": false,
    "blankSelection": "Select an option",
    "label": "Country",
    "name": "country",
    "options": [
      {
        "value": "us",
        "text": "United States"
      },
      {
        "value": "ca",
        "text": "Canada"
      },
      {
        "value": "uk",
        "text": "United Kingdom"
      },
      {
        "value": "au",
        "text": "Australia"
      }
    ],
    "value": "us"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "name",
        "value",
        "options",
        "blankSelection"
      ]
    },
    {
      "name": "State",
      "props": [
        "disabled",
        "error",
        "required",
        "requiredIndicator",
        "onChange"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "inline",
        "compact",
        "showArrow",
        "multiple"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "label": "Country",
        "name": "country",
        "value": "us",
        "options": [
          {
            "value": "us",
            "text": "United States"
          },
          {
            "value": "ca",
            "text": "Canada"
          },
          {
            "value": "uk",
            "text": "United Kingdom"
          },
          {
            "value": "au",
            "text": "Australia"
          }
        ]
      }
    },
    {
      "name": "With Error",
      "props": {
        "label": "Department",
        "name": "department",
        "value": "",
        "blankSelection": "Select a department",
        "error": "Please choose a department.",
        "options": [
          {
            "value": "eng",
            "text": "Engineering"
          },
          {
            "value": "design",
            "text": "Design"
          },
          {
            "value": "sales",
            "text": "Sales"
          }
        ]
      }
    },
    {
      "name": "Multiple",
      "props": {
        "label": "Teams",
        "name": "teams",
        "multiple": true,
        "options": [
          {
            "value": "eng",
            "text": "Engineering"
          },
          {
            "value": "design",
            "text": "Design"
          },
          {
            "value": "ops",
            "text": "Operations"
          }
        ]
      }
    },
    {
      "name": "Inline Compact",
      "props": {
        "label": "Priority",
        "name": "priority",
        "value": "medium",
        "inline": true,
        "compact": true,
        "options": [
          {
            "value": "low",
            "text": "Low"
          },
          {
            "value": "medium",
            "text": "Medium"
          },
          {
            "value": "high",
            "text": "High"
          }
        ]
      }
    }
  ],
  "conditionals": {
    "requiredIndicator": {
      "requires": "label"
    }
  },
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default shows a labeled select with a selected value and a simple options array.",
      "type": "info"
    },
    "error": {
      "presetName": "With Error",
      "message": "With Error passes an error message and blank selection for validation states.",
      "type": "info"
    },
    "multiple": {
      "presetName": "Multiple",
      "message": "Multiple switches the native select into multi-select mode using the same options shape.",
      "type": "info"
    },
    "inline_compact": {
      "presetName": "Inline Compact",
      "message": "Inline Compact combines inline and compact for dense form layouts.",
      "type": "info"
    }
  },
  "hiddenProps": [
    "inputOptions",
    "includeBlank"
  ]
}
