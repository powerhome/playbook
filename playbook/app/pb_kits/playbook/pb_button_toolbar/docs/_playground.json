{
  "template": "<ButtonToolbar{{props}}>\n  {{children}}\n</ButtonToolbar>",
  "propTargets": {},
  "defaults": {
    "connected": false,
    "orientation": "horizontal",
    "variant": "primary"
  },
  "groups": [
    {
      "name": "Layout",
      "props": [
        "orientation",
        "connected"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "variant"
      ]
    },
    {
      "name": "Content",
      "props": [
        "text"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "orientation": "horizontal",
        "variant": "primary"
      },
      "children": "<Button text=\"Create\" />\n<Button text=\"Edit\" />\n<Button text=\"Delete\" />"
    },
    {
      "name": "Vertical",
      "props": {
        "orientation": "vertical",
        "variant": "primary"
      },
      "children": "<Button text=\"Create\" />\n<Button text=\"Edit\" />\n<Button text=\"Copy\" />\n<Button text=\"Cut\" />"
    },
    {
      "name": "Secondary",
      "props": {
        "orientation": "horizontal",
        "variant": "secondary"
      },
      "children": "<Button text=\"Save\" variant=\"secondary\" />\n<Button text=\"Cancel\" variant=\"secondary\" />"
    },
    {
      "name": "Connected",
      "props": {
        "orientation": "horizontal",
        "variant": "primary",
        "connected": true
      },
      "children": "<Button text=\"Left\" />\n<Button text=\"Center\" />\n<Button text=\"Right\" />"
    },
    {
      "name": "Icon Buttons",
      "props": {
        "orientation": "horizontal",
        "variant": "secondary"
      },
      "children": "<Button icon=\"bold\" variant=\"secondary\" />\n<Button icon=\"italic\" variant=\"secondary\" />\n<Button icon=\"underline\" variant=\"secondary\" />"
    }
  ],
  "conditionals": {
    "text": {
      "hides": "children"
    }
  },
  "hints": {
    "container_usage": {
      "when": {},
      "message": "ButtonToolbar is a container for Button components. Add Button children to create grouped actions.",
      "type": "info"
    },
    "connected_mode": {
      "when": {
        "connected": true
      },
      "message": "Connected mode visually joins buttons together, useful for toggle groups or segmented controls.",
      "type": "info"
    }
  },
  "children": {
    "editable": true,
    "default": "<Button text=\"Create\" />\n<Button text=\"Edit\" />\n<Button text=\"Delete\" />",
    "hideWhenPropSet": [
      "text"
    ]
  }
}
