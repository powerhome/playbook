{
  "groups": [
    {
      "name": "Content",
      "props": ["label", "name", "options"]
    },
    {
      "name": "State",
      "props": ["disabled", "error", "required", "requiredIndicator", "validation"]
    },
    {
      "name": "Appearance",
      "props": ["inputDisplay"]
    },
    {
      "name": "Async & data",
      "props": [
        "async",
        "createable",
        "loadOptions",
        "getOptionLabel",
        "getOptionValue",
        "optionsByContext",
        "searchContextSelector",
        "clearOnContextChange",
        "preserveSearchInput"
      ]
    },
    {
      "name": "Advanced",
      "props": ["components", "onChange"]
    }
  ],
  "presets": [
    {
      "name": "Basic list",
      "props": {
        "label": "Colors",
        "options": [
          { "label": "Orange", "value": "#FFA500" },
          { "label": "Red", "value": "#FF0000" },
          { "label": "Green", "value": "#00FF00" },
          { "label": "Blue", "value": "#0000FF" }
        ]
      }
    },
    {
      "name": "Pills display",
      "props": {
        "label": "Tags",
        "inputDisplay": "pills",
        "options": [
          { "label": "Design", "value": "design" },
          { "label": "Engineering", "value": "engineering" },
          { "label": "Support", "value": "support" }
        ]
      }
    },
    {
      "name": "Plain input",
      "props": {
        "label": "Team",
        "inputDisplay": "none",
        "options": [
          { "label": "North", "value": "north" },
          { "label": "South", "value": "south" }
        ]
      }
    },
    {
      "name": "Disabled",
      "props": {
        "label": "Read only",
        "disabled": true,
        "options": [{ "label": "Only option", "value": "one" }]
      }
    },
    {
      "name": "With error",
      "props": {
        "label": "Assignee",
        "error": "Selection is required.",
        "options": [
          { "label": "Ada", "value": "ada" },
          { "label": "Grace", "value": "grace" }
        ]
      }
    },
    {
      "name": "Creatable",
      "props": {
        "label": "Add labels",
        "createable": true,
        "options": [
          { "label": "Bug", "value": "bug" },
          { "label": "Feature", "value": "feature" }
        ]
      }
    }
  ],
  "conditionals": {
    "loadOptions": { "requires": { "async": true } },
    "getOptionLabel": { "requires": { "async": true } },
    "getOptionValue": { "requires": { "async": true } },
    "optionsByContext": { "requires": "searchContextSelector" },
    "clearOnContextChange": { "requires": "searchContextSelector" }
  },
  "hints": {
    "async_options": {
      "when": { "async": true },
      "message": "Async mode expects loadOptions to return option objects with label and value.",
      "type": "info"
    }
  }
}
