{
  "template": "<Typeahead{{props}} />",
  "propTargets": {},
  "defaults": {
    "async": false,
    "createable": false,
    "disabled": false,
    "error": "",
    "inputDisplay": "pills",
    "required": false,
    "requiredIndicator": false,
    "clearOnContextChange": true,
    "preserveSearchInput": false
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "name",
        "options",
        "inputDisplay",
        "isMulti"
      ]
    },
    {
      "name": "State",
      "props": [
        "disabled",
        "error",
        "required",
        "requiredIndicator",
        "validation"
      ]
    },
    {
      "name": "Async & Data",
      "props": [
        "async",
        "loadOptions",
        "getOptionLabel",
        "getOptionValue",
        "optionsByContext",
        "searchContextSelector",
        "clearOnContextChange"
      ]
    },
    {
      "name": "Behavior",
      "props": [
        "createable",
        "preserveSearchInput",
        "onChange"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "components",
        "dark",
        "marginBottom"
      ]
    }
  ],
  "presets": [
    {
      "name": "Basic list",
      "props": {
        "label": "Colors",
        "name": "color",
        "options": [
          {
            "label": "Orange",
            "value": "#FFA500"
          },
          {
            "label": "Red",
            "value": "#FF0000"
          },
          {
            "label": "Green",
            "value": "#00FF00"
          },
          {
            "label": "Blue",
            "value": "#0000FF"
          }
        ]
      }
    },
    {
      "name": "Count display",
      "props": {
        "label": "Tags",
        "name": "tags",
        "inputDisplay": "none",
        "isMulti": true,
        "options": [
          {
            "label": "Design",
            "value": "design"
          },
          {
            "label": "Engineering",
            "value": "engineering"
          },
          {
            "label": "Support",
            "value": "support"
          }
        ]
      }
    },
    {
      "name": "Required validation",
      "props": {
        "label": "Assignee",
        "name": "assignee",
        "required": true,
        "requiredIndicator": true,
        "validation": {
          "message": "Choose an assignee."
        },
        "error": "Selection is required.",
        "options": [
          {
            "label": "Ada",
            "value": "ada"
          },
          {
            "label": "Grace",
            "value": "grace"
          }
        ]
      }
    },
    {
      "name": "Async users",
      "structureMode": "advanced",
      "props": {
        "async": true,
        "label": "Users",
        "name": "users",
        "loadOptions": "playgroundTypeahead.loadOptions",
        "getOptionLabel": "playgroundTypeahead.getOptionLabel",
        "getOptionValue": "playgroundTypeahead.getOptionValue",
        "options": []
      }
    },
    {
      "name": "Custom menu",
      "structureMode": "advanced",
      "props": {
        "label": "Colors",
        "name": "custom_menu",
        "components": {
          "__playgroundCode": "{ MenuList }"
        },
        "marginBottom": "none",
        "options": [
          {
            "label": "Orange",
            "value": "#FFA500"
          },
          {
            "label": "Red",
            "value": "#FF0000"
          },
          {
            "label": "Green",
            "value": "#00FF00"
          }
        ]
      }
    },
    {
      "name": "Creatable handler",
      "props": {
        "label": "Add labels",
        "name": "labels",
        "createable": true,
        "preserveSearchInput": true,
        "onChange": "(selected) => console.log(selected)",
        "options": [
          {
            "label": "Bug",
            "value": "bug"
          },
          {
            "label": "Feature",
            "value": "feature"
          }
        ]
      }
    }
  ],
  "conditionals": {
    "loadOptions": {
      "requires": {
        "async": true
      }
    },
    "getOptionLabel": {
      "requires": {
        "async": true
      }
    },
    "getOptionValue": {
      "requires": {
        "async": true
      }
    },
    "requiredIndicator": {
      "requires": "label"
    },
    "validation": {
      "requires": {
        "required": true
      }
    },
    "optionsByContext": {
      "requires": "searchContextSelector"
    },
    "clearOnContextChange": {
      "requires": "searchContextSelector"
    }
  },
  "hints": {
    "basic_list": {
      "presetName": "Basic list",
      "message": "Basic list uses a local options array with label and value keys.",
      "type": "info"
    },
    "count_display": {
      "presetName": "Count display",
      "message": "Count display uses multi-select with inputDisplay set to none so selected values render as a count.",
      "type": "info"
    },
    "required_validation": {
      "presetName": "Required validation",
      "message": "Required validation pairs required, requiredIndicator, validation, and error copy.",
      "type": "info"
    },
    "async_users": {
      "presetName": "Async users",
      "message": "Async users demonstrates loadOptions plus custom option label/value resolvers.",
      "type": "info"
    },
    "custom_menu": {
      "presetName": "Custom menu",
      "message": "Custom menu passes a components map to replace Typeahead.MenuList content.",
      "type": "info"
    },
    "creatable_handler": {
      "presetName": "Creatable handler",
      "message": "Creatable handler shows custom option creation, preserved search input, and an onChange handler.",
      "type": "info"
    }
  },
  "customProps": {
    "isMulti": {
      "type": "boolean",
      "platforms": [
        "react"
      ],
      "default": false
    }
  },
  "structureModes": {
    "default": "standard",
    "modes": {
      "standard": {
        "label": "Standard",
        "template": "<Typeahead{{props}} />",
        "children": ""
      },
      "advanced": {
        "label": "Advanced setup",
        "template": "<Typeahead{{props}} />",
        "children": "",
        "wrapper": "const playgroundTypeaheadOptions = [\n  { name: \"Ada Lovelace\", id: \"ada\" },\n  { name: \"Grace Hopper\", id: \"grace\" },\n  { name: \"Katherine Johnson\", id: \"katherine\" },\n  { name: \"Margaret Hamilton\", id: \"margaret\" },\n]\n\nconst playgroundTypeahead = {\n  loadOptions: (inputValue) => new Promise((resolve) => {\n    const search = inputValue.toLowerCase()\n    window.setTimeout(() => {\n      resolve(playgroundTypeaheadOptions.filter((option) => option.name.toLowerCase().includes(search)))\n    }, 250)\n  }),\n  getOptionLabel: (option) => option.name || option.label,\n  getOptionValue: (option) => String(option.id || option.value),\n}\n\nif (typeof window !== \"undefined\") {\n  window.playgroundTypeahead = playgroundTypeahead\n}\n\nconst MenuList = (props) => (\n  <Typeahead.MenuList\n      {...props}\n      footer={<Button margin=\"sm\" text=\"Custom footer\" />}\n  />\n)\n\nconst TypeaheadPlaygroundExample = () => (\n  {{component}}\n)\n\n<TypeaheadPlaygroundExample />"
      }
    }
  }
}
