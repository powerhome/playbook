{
  "$schema": "https://playbook.powerapp.cloud/schemas/kit-schema.json",
  "name": "Image",
  "description": "Image component",
  "platforms": [
    "react",
    "rails"
  ],
  "props": {
    "alt": {
      "type": "string",
      "platforms": [
        "react",
        "rails"
      ]
    },
    "onError": {
      "platforms": [
        "rails"
      ],
      "type": "string",
      "default": null
    },
    "rounded": {
      "platforms": [
        "react",
        "rails"
      ],
      "type": "boolean",
      "default": false
    },
    "size": {
      "platforms": [
        "react",
        "rails"
      ],
      "type": "enum",
      "values": [
        "xs",
        "sm",
        "md",
        "lg",
        "xl",
        "none"
      ],
      "default": "none"
    },
    "transition": {
      "platforms": [
        "react",
        "rails"
      ],
      "type": "enum",
      "values": [
        "blur",
        "fade",
        "scale",
        "none"
      ],
      "default": "fade"
    },
    "url": {
      "type": "string",
      "platforms": [
        "react",
        "rails"
      ]
    }
  },
  "globalProps": true,
  "usage": {
    "react": {
      "import": "import { Image } from 'playbook-ui'",
      "example": "<Image size=\"xs\" transition=\"blur\"></Image>"
    },
    "rails": {
      "import": null,
      "example": "<%= pb_rails(\"image\", props: { size: \"xs\", transition: \"blur\" }) %>"
    }
  }
}
