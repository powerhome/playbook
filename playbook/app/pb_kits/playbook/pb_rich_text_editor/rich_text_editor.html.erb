<%# Import map must precede each kit's module script in the DOM; repeat per kit (browsers merge identical maps). %>
<script type="importmap">
  {
    "imports": {
      "@tiptap/core": "https://cdn.jsdelivr.net/npm/@tiptap/core@2.8.0/dist/index.js",
      "@tiptap/starter-kit": "https://cdn.jsdelivr.net/npm/@tiptap/starter-kit@2.8.0/dist/index.js",
      "@tiptap/extension-link": "https://cdn.jsdelivr.net/npm/@tiptap/extension-link@2.8.0/dist/index.js",
      "@tiptap/extension-blockquote": "https://cdn.jsdelivr.net/npm/@tiptap/extension-blockquote@2.8.0/dist/index.js",
      "@tiptap/extension-bold": "https://cdn.jsdelivr.net/npm/@tiptap/extension-bold@2.8.0/dist/index.js",
      "@tiptap/extension-bullet-list": "https://cdn.jsdelivr.net/npm/@tiptap/extension-bullet-list@2.8.0/dist/index.js",
      "@tiptap/extension-code": "https://cdn.jsdelivr.net/npm/@tiptap/extension-code@2.8.0/dist/index.js",
      "@tiptap/extension-code-block": "https://cdn.jsdelivr.net/npm/@tiptap/extension-code-block@2.8.0/dist/index.js",
      "@tiptap/extension-document": "https://cdn.jsdelivr.net/npm/@tiptap/extension-document@2.8.0/dist/index.js",
      "@tiptap/extension-dropcursor": "https://cdn.jsdelivr.net/npm/@tiptap/extension-dropcursor@2.8.0/dist/index.js",
      "@tiptap/extension-gapcursor": "https://cdn.jsdelivr.net/npm/@tiptap/extension-gapcursor@2.8.0/dist/index.js",
      "@tiptap/extension-hard-break": "https://cdn.jsdelivr.net/npm/@tiptap/extension-hard-break@2.8.0/dist/index.js",
      "@tiptap/extension-heading": "https://cdn.jsdelivr.net/npm/@tiptap/extension-heading@2.8.0/dist/index.js",
      "@tiptap/extension-history": "https://cdn.jsdelivr.net/npm/@tiptap/extension-history@2.8.0/dist/index.js",
      "@tiptap/extension-horizontal-rule": "https://cdn.jsdelivr.net/npm/@tiptap/extension-horizontal-rule@2.8.0/dist/index.js",
      "@tiptap/extension-italic": "https://cdn.jsdelivr.net/npm/@tiptap/extension-italic@2.8.0/dist/index.js",
      "@tiptap/extension-list-item": "https://cdn.jsdelivr.net/npm/@tiptap/extension-list-item@2.8.0/dist/index.js",
      "@tiptap/extension-ordered-list": "https://cdn.jsdelivr.net/npm/@tiptap/extension-ordered-list@2.8.0/dist/index.js",
      "@tiptap/extension-paragraph": "https://cdn.jsdelivr.net/npm/@tiptap/extension-paragraph@2.8.0/dist/index.js",
      "@tiptap/extension-strike": "https://cdn.jsdelivr.net/npm/@tiptap/extension-strike@2.8.0/dist/index.js",
      "@tiptap/extension-text": "https://cdn.jsdelivr.net/npm/@tiptap/extension-text@2.8.0/dist/index.js",
      "@tiptap/extension-text-style": "https://cdn.jsdelivr.net/npm/@tiptap/extension-text-style@2.8.0/dist/index.js",
      "@tiptap/pm/state": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/state/dist/index.js",
      "@tiptap/pm/view": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/view/dist/index.js",
      "@tiptap/pm/keymap": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/keymap/dist/index.js",
      "@tiptap/pm/model": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/model/dist/index.js",
      "@tiptap/pm/transform": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/transform/dist/index.js",
      "@tiptap/pm/commands": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/commands/dist/index.js",
      "@tiptap/pm/schema-list": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/schema-list/dist/index.js",
      "@tiptap/pm/history": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/history/dist/index.js",
      "@tiptap/pm/gapcursor": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/gapcursor/dist/index.js",
      "@tiptap/pm/dropcursor": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/dropcursor/dist/index.js",
      "@tiptap/pm/inputrules": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/inputrules/dist/index.js",
      "@tiptap/pm/schema-basic": "https://cdn.jsdelivr.net/npm/@tiptap/pm@2.8.0/schema-basic/dist/index.js",
      "prosemirror-model": "https://cdn.jsdelivr.net/npm/prosemirror-model@1.22.3/dist/index.js",
      "prosemirror-state": "https://cdn.jsdelivr.net/npm/prosemirror-state@1.4.3/dist/index.js",
      "prosemirror-view": "https://cdn.jsdelivr.net/npm/prosemirror-view@1.33.10/dist/index.js",
      "prosemirror-transform": "https://cdn.jsdelivr.net/npm/prosemirror-transform@1.10.0/dist/index.js",
      "prosemirror-commands": "https://cdn.jsdelivr.net/npm/prosemirror-commands@1.6.0/dist/index.js",
      "prosemirror-keymap": "https://cdn.jsdelivr.net/npm/prosemirror-keymap@1.2.2/dist/index.js",
      "prosemirror-history": "https://cdn.jsdelivr.net/npm/prosemirror-history@1.4.1/dist/index.js",
      "prosemirror-gapcursor": "https://cdn.jsdelivr.net/npm/prosemirror-gapcursor@1.3.2/dist/index.js",
      "prosemirror-dropcursor": "https://cdn.jsdelivr.net/npm/prosemirror-dropcursor@1.8.1/dist/index.js",
      "prosemirror-inputrules": "https://cdn.jsdelivr.net/npm/prosemirror-inputrules@1.4.0/dist/index.js",
      "prosemirror-schema-basic": "https://cdn.jsdelivr.net/npm/prosemirror-schema-basic@1.2.3/dist/index.js",
      "prosemirror-schema-list": "https://cdn.jsdelivr.net/npm/prosemirror-schema-list@1.4.1/dist/index.js",
      "linkifyjs": "https://cdn.jsdelivr.net/npm/linkifyjs@4.1.0/dist/linkify.es.js",
      "orderedmap": "https://cdn.jsdelivr.net/npm/orderedmap@2.1.1/dist/index.js",
      "w3c-keyname": "https://cdn.jsdelivr.net/npm/w3c-keyname@2.2.8/index.js",
      "rope-sequence": "https://cdn.jsdelivr.net/npm/rope-sequence@1.3.4/dist/index.js"
    }
  }
</script>
<%= pb_content_tag(:div, id: object.container_id, class: object.classname, data: { pb_rte_tiptap: true, input_id: object.input_id, initial_html: object.initial_html }) do %>
  <div class="pb_rich_text_editor_kit">
  <% if object.label.present? %>
    <label for="<%= object.input_id %>">
      <% if object.required_indicator %>
        <%= pb_rails("caption", props: { color: "lighter", text: object.label, dark: object.dark }) %><span style="color: #DA0014;"> *</span>
      <% else %>
        <%= pb_rails("caption", props: { color: "lighter", text: object.label, dark: object.dark }) %>
      <% end %>
    </label>
  <% end %>
  <input type="hidden" name="<%= object.input_name %>" id="<%= object.input_id %>" value="" />
  <div class="pb_rich_text_editor_advanced_container toolbar-active<%= " pb_rich_text_editor_rte--simple" if object.simple %>">
    <% if object.simple %>
    <%# Compact toolbar: Bold/Italic + Undo/Redo — no block-style Popover (avoids dialog positioning issues). %>
    <div class="pb_background_kit pb_background_color_white toolbar rte-rails-toolbar-layout rte-rails-toolbar-layout--simple" id="<%= object.toolbar_id %>">
      <div class="rte-rails-toolbar-row">
        <div class="toolbar_block rte-toolbar-left">
          <button type="button" class="toolbar_button" data-action="bold" title="Bold" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "bold", size: "lg" }) %>
            <% end %>
          </button>
          <button type="button" class="toolbar_button" data-action="italic" title="Italic" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "italic", size: "lg" }) %>
            <% end %>
          </button>
        </div>
        <div class="toolbar_block rte-toolbar-right">
          <button type="button" class="toolbar_button" data-action="undo" title="Undo" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "undo", size: "lg" }) %>
            <% end %>
          </button>
          <button type="button" class="toolbar_button" data-action="redo" title="Redo" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "redo", size: "lg" }) %>
            <% end %>
          </button>
        </div>
      </div>
    </div>
    <% else %>
    <% block_style_options = [
      { value: "paragraph", text: "Paragraph", icon: "paragraph" },
      { value: "heading-1", text: "Heading 1", icon: "h1" },
      { value: "heading-2", text: "Heading 2", icon: "h2" },
      { value: "heading-3", text: "Heading 3", icon: "h3" },
      { value: "bulletList", text: "Bullet List", icon: "list" },
      { value: "orderedList", text: "Ordered List", icon: "list-ol" },
      { value: "blockquote", text: "Block Quote", icon: "block-quote" },
    ] %>
    <div class="pb_background_kit pb_background_color_white toolbar rte-rails-toolbar-layout" id="<%= object.toolbar_id %>">
      <div class="rte-rails-toolbar-row">
        <div class="toolbar_block rte-toolbar-left">
          <span class="pb_popover_reference_wrapper">
            <%# Button kit wraps content in <span class="pb_button_content"> — block <div>s inside are invalid and break layout. Single <span> row + JS sync from templates. %>
            <%= pb_rails("button", props: {
              id: object.rte_block_style_trigger_id,
              variant: "secondary",
              classname: "editor-dropdown-button",
              html_options: {
                type: "button",
                "aria-label": "Text style",
                "aria-haspopup": "true",
              },
            }) do %>
              <span class="pb_flex_kit pb_flex_kit_orientation_row pb_flex_kit_justify_content_left pb_flex_kit_align_items_center pb_flex_kit_spacing_none pb_flex_kit_gap_xs gap_xs rte-block-style-trigger-inner" data-rte-block-trigger>
                <span class="rte-block-style-trigger-icon">
                  <%= pb_rails("icon", props: { icon: "paragraph", size: "lg" }) %>
                </span>
                <span class="rte-block-style-trigger-label">Paragraph</span>
                <span class="display_inline_flex rte-block-style-chevron">
                  <%= pb_rails("icon", props: { icon: "chevron-down", fixed_width: true }) %>
                </span>
              </span>
            <% end %>
          </span>
          <%= pb_rails("popover", props: {
            trigger_element_id: object.rte_block_style_trigger_id,
            tooltip_id: object.rte_block_style_tooltip_id,
            position: "bottom",
            padding: "none",
            close_on_click: "any",
            offset: true,
          }) do %>
            <%= pb_rails("nav", props: { variant: "subtle", padding_top: "xs", padding_bottom: "xs" }) do %>
              <% block_style_options.each do |opt| %>
                <%= pb_rails("nav/item", props: {
                  link: "##{opt[:value]}",
                  text: opt[:text],
                  icon_left: opt[:icon],
                  margin: "none",
                  padding_top: "xxs",
                  padding_bottom: "xxs",
                }) %>
              <% end %>
            <% end %>
          <% end %>
          <%= pb_rails("section_separator", props: { orientation: "vertical" }) %>
          <button type="button" class="toolbar_button" data-action="bold" title="Bold" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "bold", size: "lg" }) %>
            <% end %>
          </button>
          <button type="button" class="toolbar_button" data-action="italic" title="Italic" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "italic", size: "lg" }) %>
            <% end %>
          </button>
          <button type="button" class="toolbar_button" data-action="strike" title="Strikethrough" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "strikethrough", size: "lg" }) %>
            <% end %>
          </button>
          <%= pb_rails("section_separator", props: { orientation: "vertical" }) %>
          <button type="button" class="toolbar_button" data-action="codeBlock" title="Code block" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "code", size: "lg" }) %>
            <% end %>
          </button>
          <button type="button" class="toolbar_button" data-action="link" title="Link" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "link", size: "lg" }) %>
            <% end %>
          </button>
        </div>
        <div class="toolbar_block rte-toolbar-right">
          <button type="button" class="toolbar_button" data-action="undo" title="Undo" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "undo", size: "lg" }) %>
            <% end %>
          </button>
          <button type="button" class="toolbar_button" data-action="redo" title="Redo" role="button" tabindex="0">
            <%= pb_rails("flex", props: { align: "center", justify: "center", classname: "toolbar_button_icon" }) do %>
              <%= pb_rails("icon", props: { icon: "redo", size: "lg" }) %>
            <% end %>
          </button>
        </div>
      </div>
    </div>
    <div id="<%= object.container_id %>-block-icon-templates" hidden aria-hidden="true">
      <% block_style_options.each do |opt| %>
        <span data-block-template-for="<%= opt[:value] %>" data-label="<%= opt[:text] %>">
          <%= pb_rails("icon", props: { icon: opt[:icon], size: "lg" }) %>
        </span>
      <% end %>
    </div>
    <% end %>
    <div class="rte-editor-wrap">
      <div id="<%= object.editor_node_id %>"></div>
    </div>
  </div>
  </div>
<% end %>

<script type="module">
(async function() {
  const container = document.getElementById("<%= object.container_id %>");
  if (!container) return;
  const inputId = container.dataset.inputId;
  let initialHtml = container.dataset.initialHtml || "<p></p>";
  if (initialHtml && !initialHtml.trim().startsWith("<")) {
    initialHtml = "<p>" + initialHtml + "</p>";
  }
  const hiddenInput = document.getElementById(inputId);
  const editorNode = document.getElementById("<%= object.editor_node_id %>");
  const toolbar = document.getElementById("<%= object.toolbar_id %>");
  const rteSimple = <%= object.simple ? "true" : "false" %> === "true";
  const blockTooltipId = "<%= object.rte_block_style_tooltip_id %>";
  const iconTemplatesRoot = rteSimple ? null : document.getElementById("<%= object.container_id %>-block-icon-templates");
  if (!editorNode || !hiddenInput || !toolbar) return;

  function syncToHiddenInput(editor) {
    if (editor && hiddenInput) {
      hiddenInput.value = editor.getHTML();
    }
  }

  const { Editor } = await import("@tiptap/core");
  const { default: StarterKit } = await import("@tiptap/starter-kit");
  const { default: Link } = await import("@tiptap/extension-link");

  const editor = new Editor({
    element: editorNode,
    extensions: [
      StarterKit.configure({ heading: { levels: [1, 2, 3] } }),
      Link.configure({ openOnClick: false, HTMLAttributes: { target: "_blank", rel: "noopener" } }),
    ],
    content: initialHtml,
    editable: true,
    onUpdate: ({ editor: ed }) => syncToHiddenInput(ed),
  });

  syncToHiddenInput(editor);

  const actionToChain = {
    bold: "toggleBold",
    italic: "toggleItalic",
    strike: "toggleStrike",
    codeBlock: "toggleCodeBlock",
  };

  function getCurrentBlockValue() {
    let value = "paragraph";
    if (editor.isActive("heading", { level: 1 })) value = "heading-1";
    else if (editor.isActive("heading", { level: 2 })) value = "heading-2";
    else if (editor.isActive("heading", { level: 3 })) value = "heading-3";
    else if (editor.isActive("bulletList")) value = "bulletList";
    else if (editor.isActive("orderedList")) value = "orderedList";
    else if (editor.isActive("blockquote")) value = "blockquote";
    return value;
  }

  function syncBlockTrigger() {
    if (rteSimple) return;
    const current = getCurrentBlockValue();
    const triggerRoot = toolbar.querySelector("[data-rte-block-trigger]");
    let tpl = iconTemplatesRoot && [...iconTemplatesRoot.children].find(
      (el) => el.getAttribute("data-block-template-for") === current
    );
    if (!tpl && iconTemplatesRoot) {
      tpl = [...iconTemplatesRoot.children].find(
        (el) => el.getAttribute("data-block-template-for") === "paragraph"
      );
    }
    if (triggerRoot && tpl) {
      const iconWrap = triggerRoot.querySelector(".rte-block-style-trigger-icon");
      const labelEl = triggerRoot.querySelector(".rte-block-style-trigger-label");
      if (iconWrap) iconWrap.innerHTML = tpl.innerHTML;
      if (labelEl) labelEl.textContent = tpl.getAttribute("data-label") || "";
    }
    const tooltip = document.getElementById(blockTooltipId);
    if (tooltip) {
      tooltip.querySelectorAll("a.pb_nav_list_item_link").forEach((a) => {
        const href = a.getAttribute("href") || "";
        const v = href.startsWith("#") ? href.slice(1) : "";
        a.classList.toggle("is-active", v === current);
      });
    }
  }

  function applyBlockType(value) {
    const chain = editor.chain().focus();
    if (value === "paragraph") chain.setParagraph().run();
    else if (value === "heading-1") chain.toggleHeading({ level: 1 }).run();
    else if (value === "heading-2") chain.toggleHeading({ level: 2 }).run();
    else if (value === "heading-3") chain.toggleHeading({ level: 3 }).run();
    else if (value === "bulletList") chain.toggleBulletList().run();
    else if (value === "orderedList") chain.toggleOrderedList().run();
    else if (value === "blockquote") chain.toggleBlockquote().run();
  }

  if (!rteSimple) {
    const blockStyleTooltip = document.getElementById(blockTooltipId);
    if (blockStyleTooltip) {
      blockStyleTooltip.addEventListener("click", (e) => {
        const a = e.target.closest("a[href^='#']");
        if (!a || !blockStyleTooltip.contains(a)) return;
        e.preventDefault();
        const href = a.getAttribute("href") || "";
        const v = href.startsWith("#") ? href.slice(1) : "";
        if (!v) return;
        applyBlockType(v);
        updateActiveStates();
      });
    }
  }

  function updateActiveStates() {
    syncBlockTrigger();
    toolbar.querySelectorAll("button[data-action]").forEach((btn) => {
      const action = btn.dataset.action;
      let active = false;
      if (action === "bold") active = editor.isActive("bold");
      else if (action === "italic") active = editor.isActive("italic");
      else if (action === "strike") active = editor.isActive("strike");
      else if (action === "codeBlock") active = editor.isActive("codeBlock");
      else if (action === "link") active = editor.isActive("link");
      btn.classList.toggle("is-active", active);
    });
    toolbar.querySelectorAll("button[data-action='undo']").forEach((btn) => {
      btn.disabled = !editor.can().undo();
    });
    toolbar.querySelectorAll("button[data-action='redo']").forEach((btn) => {
      btn.disabled = !editor.can().redo();
    });
  }

  toolbar.addEventListener("click", (e) => {
    const btn = e.target.closest("button[data-action]");
    if (!btn) return;
    e.preventDefault();
    const action = btn.dataset.action;

    if (action === "undo") {
      editor.chain().focus().undo().run();
    } else if (action === "redo") {
      editor.chain().focus().redo().run();
    } else if (action === "link") {
      const previousUrl = editor.getAttributes("link").href || "";
      const url = window.prompt("URL", previousUrl);
      if (url === null) return;
      if (url === "") {
        editor.chain().focus().extendMarkRange("link").unsetLink().run();
      } else {
        editor.chain().focus().extendMarkRange("link").setLink({ href: url }).run();
      }
    } else {
      const chainMethod = actionToChain[action];
      if (chainMethod && typeof editor.chain().focus()[chainMethod] === "function") {
        editor.chain().focus()[chainMethod]().run();
      }
    }
    updateActiveStates();
  });

  editor.on("selectionUpdate", updateActiveStates);
  editor.on("transaction", updateActiveStates);
  updateActiveStates();
})();
</script>
