{
  "hiddenProps": ["inputOptions", "onChange"],
  "groups": [
    {
      "name": "Content",
      "props": ["name", "value"]
    },
    {
      "name": "State",
      "props": ["checked", "disabled"]
    },
    {
      "name": "Appearance",
      "props": ["size"]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "name": "marketing_emails",
        "value": "opt_in"
      }
    },
    {
      "name": "Checked",
      "props": {
        "name": "dark_mode",
        "value": "theme",
        "checked": true
      }
    },
    {
      "name": "Disabled",
      "props": {
        "name": "auto_save",
        "value": "enabled",
        "checked": true,
        "disabled": true
      }
    }
  ],
  "conditionals": {},
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default renders an unchecked small toggle with name and value for forms.",
      "type": "info"
    },
    "checked": {
      "presetName": "Checked",
      "message": "Checked initializes the toggle in the on state.",
      "type": "info"
    },
    "disabled": {
      "presetName": "Disabled",
      "message": "Disabled keeps the selected state visible while preventing changes.",
      "type": "info"
    }
  }
}
