      "props": {
        "datetime": "2026-04-09T15:30:00.000Z"
      }
    },
    {
      "name": "Small",
      "props": {
        "datetime": "2026-04-09T15:30:00.000Z",
        "size": "sm"
      }
    },
    {
      "name": "With weekday",
      "props": {
        "datetime": "2026-06-12T11:00:00.000Z",
        "showDayOfWeek": true
      }
    },
    {
      "name": "With calendar icon",
      "props": {
        "datetime": "2026-04-09T15:30:00.000Z",
        "showIcon": true,
