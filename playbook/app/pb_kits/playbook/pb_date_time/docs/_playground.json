{
  "template": "<DateTime{{props}} />",
  "propTargets": {},
  "defaults": {
    "align": "left",
    "size": "md",
    "showCurrentYear": false,
    "showDayOfWeek": false,
    "showIcon": false
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "datetime",
        "showDayOfWeek",
        "showCurrentYear",
        "showIcon",
        "timeZone"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "size",
        "align"
      ]
    }
  ],
  "presets": [
