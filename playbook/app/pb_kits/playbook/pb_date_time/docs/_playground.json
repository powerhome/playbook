      }
    },
    {
      "name": "Centered",
      "props": {
        "datetime": "2026-04-09T15:30:00.000Z",
        "align": "center"
      }
    },
    {
      "name": "Tokyo time",
      "props": {
        "datetime": "2026-04-09T15:30:00.000Z",
        "timeZone": "Asia/Tokyo"
      }
