  "defaults": {
    "autocomplete": false,
    "blankSelection": "",
    "clearable": true,
    "closeOnClick": "any",
    "constrainHeight": false,
    "multiSelect": false,
    "separators": true,
    "variant": "default",
    "rangeEndsToday": false,
    "controlsStartId": "",
    "controlsEndId": "",
