        "customQuickPickDates",
        "rangeEndsToday",
        "controlsStartId",
        "controlsEndId"
      ]
    },
    {
      "name": "Display",
      "props": [
        "separators",
        "formPillProps",
        "activeStyle",
        "dark"
      ]
    },
    {
      "name": "Events",
