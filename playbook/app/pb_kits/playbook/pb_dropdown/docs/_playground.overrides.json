{
  "structureModes": {
    "default": "simple",
    "modes": {
      "simple": {
        "label": "Simple",
        "template": "<Dropdown options={options}{{props}} />",
        "children": ""
      },
      "subcomponents": {
        "label": "With Subcomponents",
        "template": "<Dropdown options={options}{{props}}>\n  <Dropdown.Trigger />\n  <Dropdown.Container>\n    {options.map((option) => (\n      <Dropdown.Option key={option.id} option={option} />\n    ))}\n  </Dropdown.Container>\n</Dropdown>",
        "children": ""
      }
    }
  },
  "customProps": {
    "options": {
      "type": "array",
      "platforms": ["react", "rails"],
      "description": "Dropdown option data with label, value, id, and optional disabled state."
    }
  },
  "requiredProps": {
    "options": [
      { "label": "United States", "value": "unitedStates", "id": "us" },
      { "label": "Canada", "value": "canada", "id": "ca", "disabled": true },
      { "label": "Pakistan", "value": "pakistan", "id": "pk" },
      { "label": "Mexico", "value": "mexico", "id": "mx", "disabled": true },
      { "label": "United Kingdom", "value": "unitedKingdom", "id": "gb" },
      { "label": "India", "value": "india", "id": "in" },
      { "label": "Australia", "value": "australia", "id": "au" },
      { "label": "New Zealand", "value": "newZealand", "id": "nz" },
      { "label": "Italy", "value": "italy", "id": "it" },
      { "label": "Germany", "value": "germany", "id": "de" },
      { "label": "Brazil", "value": "brazil", "id": "br" },
      { "label": "Philippines", "value": "philippines", "id": "ph" }
    ]
  },
  "defaults": {
    "autocomplete": false,
    "blankSelection": "",
    "clearable": true,
    "closeOnClick": "any",
    "constrainHeight": false,
    "dark": false,
    "label": "Select a Country",
    "multiSelect": false,
    "options": [
      { "label": "United States", "value": "unitedStates", "id": "us" },
      { "label": "Canada", "value": "canada", "id": "ca", "disabled": true },
      { "label": "Pakistan", "value": "pakistan", "id": "pk" },
      { "label": "Mexico", "value": "mexico", "id": "mx", "disabled": true },
      { "label": "United Kingdom", "value": "unitedKingdom", "id": "gb" },
      { "label": "India", "value": "india", "id": "in" },
      { "label": "Australia", "value": "australia", "id": "au" },
      { "label": "New Zealand", "value": "newZealand", "id": "nz" },
      { "label": "Italy", "value": "italy", "id": "it" },
      { "label": "Germany", "value": "germany", "id": "de" },
      { "label": "Brazil", "value": "brazil", "id": "br" },
      { "label": "Philippines", "value": "philippines", "id": "ph" }
    ],
    "placeholder": "Select a country",
    "requiredIndicator": false,
    "separators": true,
    "variant": "default"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "placeholder",
        "options",
        "defaultValue",
        "blankSelection",
        "error"
      ]
    },
    {
      "name": "Behavior",
      "props": [
        "variant",
        "multiSelect",
        "autocomplete",
        "clearable",
        "closeOnClick",
        "constrainHeight",
        "isClosed",
        "requiredIndicator"
      ]
    },
    {
      "name": "Quick pick",
      "props": [
        "customQuickPickDates",
        "rangeEndsToday",
        "controlsStartId",
        "controlsEndId"
      ]
    },
    {
      "name": "Display",
      "props": [
        "separators",
        "formPillProps",
        "activeStyle",
        "dark",
        "disabled"
      ]
    },
    {
      "name": "Events",
      "props": ["onSelect"]
    }
  ],
  "presets": [
    {
      "name": "Default trigger",
      "props": {
        "variant": "default",
        "placeholder": "Select a country"
      }
    },
    {
      "name": "With label",
      "props": {
        "label": "Select a Country",
        "placeholder": "Choose a country"
      }
    },
    {
      "name": "Disabled options",
      "props": {
        "label": "Select a Country",
        "placeholder": "Choose a country"
      }
    },
    {
      "name": "Subtle Variant",
      "props": {
        "variant": "subtle",
        "separators": false
      }
    },
    {
      "name": "Quick pick",
      "props": {
        "variant": "quickpick",
        "label": "Date Range",
        "placeholder": "Select a Date Range"
      }
    },
    {
      "name": "Quick pick custom",
      "props": {
        "variant": "quickpick",
        "label": "Date Range",
        "customQuickPickDates": {
          "dates": [
            {
              "label": "Last 15 months",
              "value": {
                "timePeriod": "months",
                "amount": 15
              }
            },
            {
              "label": "First Week of June 2022",
              "value": ["06/01/2022", "06/07/2022"]
            }
          ]
        }
      }
    },
    {
      "name": "Quick pick append defaults",
      "props": {
        "variant": "quickpick",
        "label": "Date Range",
        "customQuickPickDates": {
          "dates": [
            {
              "label": "Last 15 months",
              "value": {
                "timePeriod": "months",
                "amount": 15
              }
            },
            {
              "label": "First Week of June 2022",
              "value": ["06/01/2022", "06/07/2022"]
            }
          ],
          "override": false
        }
      }
    },
    {
      "name": "Multi-select",
      "props": {
        "variant": "default",
        "multiSelect": true,
        "placeholder": "Select countries"
      }
    },
    {
      "name": "Multi-select with pills",
      "props": {
        "variant": "default",
        "multiSelect": true,
        "placeholder": "Select countries",
        "formPillProps": { "size": "small", "color": "neutral" },
        "defaultValue": [
          { "label": "United States", "value": "unitedStates" },
          { "label": "Italy", "value": "italy" }
        ]
      }
    },
    {
      "name": "With error",
      "props": {
        "variant": "default",
        "label": "Required field",
        "placeholder": "Required field",
        "error": "Please make a selection."
      }
    },
    {
      "name": "Search (autocomplete)",
      "props": {
        "variant": "default",
        "autocomplete": true,
        "placeholder": "Search..."
      }
    },
    {
      "name": "Constrained height",
      "props": {
        "label": "Choose an Option",
        "constrainHeight": true
      }
    }
  ],
  "conditionals": {
    "requiredIndicator": { "requires": "label" },
    "formPillProps": { "requires": "multiSelect" },
    "rangeEndsToday": { "requires": { "variant": "quickpick" } },
    "controlsStartId": { "requires": { "variant": "quickpick" } },
    "controlsEndId": { "requires": { "variant": "quickpick" } },
    "customQuickPickDates": { "requires": { "variant": "quickpick" } }
  },
  "hints": {
    "quickpick_scope": {
      "when": { "variant": "quickpick" },
      "message": "Quick pick uses preset date-range options. Use customQuickPickDates to replace or extend them, and pair controlsStartId / controlsEndId with DatePicker when you need synced date inputs.",
      "type": "info"
    },
    "multi_options": {
      "when": { "multiSelect": true },
      "message": "Multi-select returns arrays of selected options. Use formPillProps to adjust the selected-pill appearance and clearable to let users reset the selection.",
      "type": "info"
    },
    "autocomplete_info": {
      "when": { "autocomplete": true },
      "message": "Autocomplete filters the provided options list in place. It works especially well with longer option sets.",
      "type": "info"
    },
    "quickpick_custom_info": {
      "presetName": "Quick pick custom",
      "message": "When override is omitted or true, customQuickPickDates replaces the default quick-pick menu.",
      "type": "info"
    },
    "quickpick_append_info": {
      "presetName": "Quick pick append defaults",
      "message": "Set customQuickPickDates.override to false to append your custom ranges to the built-in quick-pick options.",
      "type": "info"
    },
    "constrained_height_info": {
      "presetName": "Constrained height",
      "message": "constrainHeight restricts the height of the dropdown menu and enables vertical scrolling when the content exceeds this height. This prevents long dropdown lists from rendering off-screen.",
      "type": "info"
    },
    "disabled_options_info": {
      "presetName": "Disabled options",
      "message": "Set disabled: true on individual option objects to keep them visible while preventing selection.",
      "type": "info"
    },
    "subcomponent_structure_info": {
      "message": "Switch Structure to “With Subcomponents” to see the explicit Dropdown.Trigger, Dropdown.Container, and Dropdown.Option composition API.",
      "type": "info"
    }
  }
}
