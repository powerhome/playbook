<%= pb_content_tag(:div) do %>
    <%= object.wrapper do %>
      <%= pb_rails("flex", props: { orientation: "row", padding_right: "lg", vertical: "center" }) do %>
        <% if (object.template != "sort_only") %>
          <%= pb_rails("circle_icon_button", props: { variant: "secondary", icon: "filter", id:"filter#{object.id}"}) %>
          <div class="maskContainer">
            <div class="filters">
              <div class="left_gradient"></div>
              <% interactive_filters_rendered = 0 %>
              <% if object.filters&.none? { |filter| filter[:name].present? } %>
                <div>
                  <%= pb_rails("body", props: {
                    color: "light",
                    padding_left: "xs",
                    size: 4,
                    tag:"span",
                    text: "No Filter Selected"
                  }) %>
                </div>
              <% end %>
              <% object.filters&.each do |filter| %>
                <% next unless filter[:name].present? %>
                <% interactive_config = object.interactive_config_for(filter[:name]) %>
                <% if interactive_config.present? && interactive_filters_rendered < 4 %>
                  <%
                    interactive_filters_rendered += 1
                    chip_id        = "pb-interactive-filter-#{object.id || 'kit'}-#{filter[:name].to_s.parameterize}"
                    popover_id     = "#{chip_id}-popover"
                    type           = object.interactive_value(interactive_config, :type).to_s
                    display_value  = object.interactive_display_value(interactive_config, filter[:value])
                    is_date_picker = type == "date-picker"
                    is_options     = %w[select dropdown].include?(type)

                    chip_data_attrs = {
                      "pb-interactive-filter" => "true",
                      "pb-filter-name"        => filter[:name],
                      "pb-filter-type"        => type,
                      "pb-filter-popover-id"  => popover_id,
                      "pb-filter-target"      => object.interactive_value(interactive_config, :target_input),
                      "pb-filter-value"       => filter[:value],
                      "pb-filter-auto-submit" => object.interactive_value(interactive_config, :auto_submit),
                    }
                    if is_date_picker
                      chip_data_attrs.merge!(
                        "pb-filter-date-format" => object.interactive_value(interactive_config, :format),
                        "pb-filter-date-mode"   => object.interactive_value(interactive_config, :mode),
                        "pb-filter-date-min"    => object.interactive_value(interactive_config, :min_date),
                        "pb-filter-date-max"    => object.interactive_value(interactive_config, :max_date),
                      )
                    end
                  %>
                  <div class="filter interactive pb_interactive_filter_desktop">
                    <button type="button"
                            class="pb_interactive_filter_trigger"
                            id="<%= chip_id %>"
                            <%= chip_data_attrs.compact_blank.map { |k, v| "data-#{k}=\"#{ERB::Util.html_escape(v)}\"" }.join(" ").html_safe %>>
                      <div class="pb_interactive_filter_text">
                        <%= pb_rails("caption", props: { text: filter[:name] }) %>
                        <%= pb_rails("flex", props: { align_items: "center", gap: "xxs" }) do %>
                          <%= pb_rails("title", props: {
                            text: display_value.presence || "—",
                            size: 4,
                            data: { "pb-filter-value-display" => true },
                          }) %>
                          <%= pb_rails("icon", props: { icon: "angle-down", fixed_width: true, size: "xs", color: "primary" }) %>
                        <% end %>
                      </div>
                    </button>

                    <%# Popover tooltip is moved to <body> in index.ts (connect)
                        to escape the filter row's overflow-x clipping. We
                        reuse pb_popover's CSS classes for visual consistency
                        rather than using the popover kit directly because
                        that kit doesn't portal its tooltip out of its DOM
                        parent. %>
                    <div class="pb_popover_tooltip hide pb_interactive_filter_editor pb_interactive_filter_editor--<%= type %>" id="<%= popover_id %>" role="tooltip">
                      <div class="pb_popover_body">
                        <% if is_options %>
                          <ul class="pb_interactive_filter_options" role="listbox">
                            <% object.interactive_options(interactive_config).each do |opt| %>
                              <% opt_value = object.interactive_option_value(interactive_config, opt) %>
                              <% is_active = opt_value.to_s == filter[:value].to_s %>
                              <% opt_label = object.interactive_option_label(opt, opt_value) %>
                              <li class="pb_interactive_filter_option<%= ' active' if is_active %>"
                                  role="option"
                                  aria-selected="<%= is_active %>"
                                  data-pb-filter-option-value="<%= opt_value %>"
                                  data-pb-filter-option-label="<%= opt_label %>">
                                <span><%= opt_label %></span>
                              </li>
                            <% end %>
                          </ul>
                        <% elsif is_date_picker %>
                          <div data-pb-filter-date-mount></div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <div class="filter pb_interactive_filter_mobile_static">
                    <%= pb_rails("caption", props: { text: filter[:name] }) %>
                    <%= pb_rails("title", props: { size: 4, tag: "h4", text: display_value }) %>
                  </div>
                <% else %>
                  <div class="filter">
                    <%= pb_rails("caption", props: { text: filter[:name] }) %>
                    <%= pb_rails("title", props: { size: 4, tag: "h4", text: interactive_config.present? ? object.interactive_display_value(interactive_config, filter[:value]) : filter[:value] }) %>
                  </div>
                <% end %>
              <% end %>
              <div class="right_gradient"></div>
            </div>
          </div>
          <% if (object.template != "default") %>
            <%= pb_rails("caption", props: {text: object.result_text, size:"xs", classname:"filter-results"})%>
          <% end %>
        <% end %>

        <% if (object.template == "single" ) || (object.template == "sort_only") %>
          <% unless object.sort_menu == [{}] %>
            <%= pb_rails("button", props: {variant: "link",id: "sort-button#{object.id}",padding_right: "none"}) do %>
              <% object.sort_menu.each do |item| %>
                <% if item[:active] == true %>
                  <%= item[:item] %>
                  <%= pb_rails("icon", props: { icon: object.sort_icon(item[:direction]), fixed_width: true }) %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>

      <% if (object.template == "default")%>
        <%= pb_rails("section_separator") %>
        <%= pb_rails("flex", props: {orientation: "row", vertical: "center", spacing: "between", classname: "filter-bottom"}) do %>
          <%= pb_rails("title_count", props: {title: "Results:",count: object.results, align:"center"}) %>
            <%= pb_rails("flex", props: {orientation: "row", vertical: "center"}) do %>
              <%= pb_rails("caption", props: { text: "sort by:"}) %>
              <%= pb_rails("button", props: {variant: "link", padding_right: "none", id: "sort-button#{object.id}"}) do %>
                <% object.sort_menu.each do |item| %>
                  <% if item[:active] == true %>
                    <%= item[:item] %>
                    <%= pb_rails("icon", props: { icon: object.sort_icon(item[:direction]), fixed_width: true }) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
        <% end %>
      <% end %>
    <% end %>

    <% if object.template != "sort_only"%>
      <%= pb_rails("popover", props: {max_height: object.max_height, min_width: object.min_width, close_on_click: "outside", trigger_element_id: "filter#{object.id}", tooltip_id: "filter-form#{object.id}", position: object.placement }.merge(object.popover_props)) do %>
        <%= content %>
      <% end %>
    <%end%>

    <% if object.template != "filter_only"%>
      <%= pb_rails("popover", props: {max_height: object.max_height, classname: "pb_filter_sort_menu", close_on_click: "outside", trigger_element_id: "sort-button#{object.id}", tooltip_id: "sort-filter-btn-tooltip#{object.id}", position: object.placement , padding: 'none'}.merge(object.popover_props)) do %>
          <%= pb_rails("list") do %>
            <% object.sort_menu.each do |item| %>
              <%= pb_rails("list/item") do%> <%= pb_rails("button", props: {variant: "link" ,classname: "p-0", text: item[:item], link: item[:link]}) %><% end %>
            <% end %>
          <% end %>
      <% end %>
    <% end %>
<% end %>
