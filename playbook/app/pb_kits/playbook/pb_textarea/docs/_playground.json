{
  "template": "<Textarea{{props}} />",
  "propTargets": {},
  "defaults": {
    "disabled": false,
    "emojiMask": false,
    "inline": false,
    "requiredIndicator": false,
    "rows": 4,
    "resize": "none"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "name",
        "placeholder",
        "value"
      ]
    },
    {
      "name": "State",
      "props": [
        "disabled",
        "error",
        "required",
        "requiredIndicator",
        "onChange"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "inline",
        "resize",
        "rows",
        "emojiMask",
        "maxCharacters",
        "characterCount"
      ]
    },
    {
      "name": "Options",
      "props": [
        "inputOptions",
        "object",
        "method"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "label": "Description",
        "name": "description",
        "placeholder": "Tell us more about your project…",
        "value": ""
      }
    },
    {
      "name": "With Error",
      "props": {
        "label": "Description",
        "name": "description",
        "placeholder": "Minimum 50 characters",
        "value": "Hi",
        "error": "Description must be at least 50 characters."
      }
    },
    {
      "name": "Disabled",
      "props": {
        "label": "Notes",
        "name": "notes",
        "placeholder": "Internal notes",
        "value": "Scheduled for next sprint.",
        "disabled": true
      }
    },
    {
      "name": "Required",
      "props": {
        "label": "Description",
        "name": "description",
        "placeholder": "This field is required",
        "value": "",
        "required": true,
        "requiredIndicator": true
      }
    }
  ],
  "conditionals": {
    "requiredIndicator": {
      "requires": "label"
    }
  },
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default shows a labeled multiline field with name, placeholder, and value.",
      "type": "info"
    },
    "with_error": {
      "presetName": "With Error",
      "message": "With Error displays validation copy below the textarea while preserving the entered text.",
      "type": "info"
    },
    "disabled": {
      "presetName": "Disabled",
      "message": "Disabled keeps existing text visible while preventing edits.",
      "type": "info"
    },
    "required": {
      "presetName": "Required",
      "message": "Required combines required with requiredIndicator so the label communicates the requirement.",
      "type": "info"
    }
  }
}
