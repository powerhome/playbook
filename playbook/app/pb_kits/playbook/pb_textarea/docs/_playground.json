{
  "template": "<Textarea{{props}} />",
  "propTargets": {},
  "defaults": {
    "disabled": false,
    "emojiMask": false,
    "inline": false,
    "requiredIndicator": false,
    "rows": 4,
    "resize": "none"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "label",
        "name",
        "placeholder",
        "value"
      ]
    },
    {
      "name": "State",
      "props": [
        "disabled",
        "error",
        "required",
        "requiredIndicator"
      ]
    },
    {
      "name": "Appearance",
      "props": [
        "inline",
        "resize",
        "rows",
        "emojiMask"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "label": "Description",
        "name": "description",
        "placeholder": "Tell us more about your project…",
        "value": ""
      }
    },
    {
      "name": "With Error",
      "props": {
        "label": "Description",
        "name": "description",
        "placeholder": "Minimum 50 characters",
        "value": "Hi",
        "error": "Description must be at least 50 characters."
      }
    },
    {
      "name": "Disabled",
      "props": {
        "label": "Notes",
        "name": "notes",
        "placeholder": "Internal notes",
        "value": "Scheduled for next sprint.",
        "disabled": true
      }
    },
    {
      "name": "Required",
      "props": {
        "label": "Description",
        "name": "description",
        "placeholder": "This field is required",
        "value": "",
        "required": true,
        "requiredIndicator": true
      }
    }
  ],
  "conditionals": {
    "requiredIndicator": {
      "requires": "label"
    }
  },
  "hints": {}
}
