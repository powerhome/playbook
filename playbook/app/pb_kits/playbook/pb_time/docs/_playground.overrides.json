{
  "groups": [
    {
      "name": "Content",
      "props": ["date", "showTimezone", "timeZone"]
    },
    {
      "name": "Appearance",
      "props": ["showIcon", "size", "align", "unstyled", "dark"]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "date": "2026-04-09T15:30:00.000Z"
      }
    },
    {
      "name": "With Icon",
      "props": {
        "date": "2026-04-09T09:15:00.000Z",
        "showIcon": true,
        "size": "md"
      }
    },
    {
      "name": "Hide timezone label",
      "props": {
        "date": "2026-04-09T15:30:00.000Z",
        "showTimezone": false
      }
    },
    {
      "name": "Pacific Time",
      "props": {
        "date": "2026-04-09T15:30:00.000Z",
        "timeZone": "America/Los_Angeles"
      }
    }
  ],
  "conditionals": {
    "timeZone": { "requires": "showTimezone" }
  },
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default renders a Date value with the kit's standard small time styling.",
      "type": "info"
    },
    "with_icon": {
      "presetName": "With Icon",
      "message": "With Icon adds the clock icon and medium sizing for a more prominent timestamp.",
      "type": "info"
    },
    "hide_timezone": {
      "presetName": "Hide timezone label",
      "message": "Hide timezone label passes showTimezone={false} while keeping the same time value.",
      "type": "info"
    },
    "pacific_time": {
      "presetName": "Pacific Time",
      "message": "Pacific Time uses timeZone to render the same Date in a specific timezone.",
      "type": "info"
    }
  }
}
