<%= pb_rails("overlay") do %>
    <%= pb_rails("table", props: { border: "default",  size: "sm" }) do %>
        <thead>
            <tr>
                <th>Column 1</th>
                <th>Column 2</th>
                <th>Column 3</th>
                <th>Column 4</th>
                <th>Column 5</th>
            </tr>
        </thead>
        <tbody>
            <% 7.times do %>
                <tr>
                    <td>Value 1</td>
                    <td>Value 2</td>
                    <td>Value 3</td>
                    <td>Value 4</td>
                    <td>Value 5</td>
                </tr>
            <% end %>   
        </tbody>
    <% end %>
<% end %>

