{
  "template": "<Timestamp timezone={timezone}{{props}} />",
  "requiredProps": {
    "timezone": "America/New_York"
  },
  "groups": [
    {
      "name": "Content",
      "props": [
        "timestamp",
        "text",
        "showDate",
        "showTime",
        "showCurrentYear",
        "showTimezone",
        "showUser",
        "hideUpdated",
        "timezone"
      ]
    },
    {
      "name": "Appearance",
      "props": ["variant", "align", "unstyled", "dark"]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "props": {
        "timestamp": "2026-04-09T15:30:00.000Z",
        "text": "Alex Chen"
      }
    },
    {
      "name": "Date only",
      "props": {
        "timestamp": "2026-04-09T15:30:00.000Z",
        "text": "",
        "showTime": false
      }
    },
    {
      "name": "With Timezone",
      "props": {
        "timestamp": "2026-04-09T15:30:00.000Z",
        "text": "",
        "showTimezone": true,
        "timezone": "America/Chicago"
      }
    },
    {
      "name": "Elapsed",
      "props": {
        "timestamp": "2026-04-08T12:00:00.000Z",
        "text": "Jordan Lee",
        "variant": "elapsed"
      }
    },
    {
      "name": "Last updated",
      "props": {
        "timestamp": "2026-04-09T14:00:00.000Z",
        "text": "Sam Rivera",
        "variant": "updated",
        "showUser": true
      }
    }
  ],
  "conditionals": {
    "showUser": { "requires": "text" }
  },
  "hints": {
    "default": {
      "presetName": "Default",
      "message": "Default renders timestamp text with both date and time.",
      "type": "info"
    },
    "date_only": {
      "presetName": "Date only",
      "message": "Date only hides the time while keeping the date visible.",
      "type": "info"
    },
    "with_timezone": {
      "presetName": "With Timezone",
      "message": "With Timezone shows the timezone label and uses a specific timezone.",
      "type": "info"
    },
    "elapsed": {
      "presetName": "Elapsed",
      "message": "Elapsed switches variant to elapsed for relative time language.",
      "type": "info"
    },
    "last_updated": {
      "presetName": "Last updated",
      "message": "Last updated uses the updated variant and showUser to include the user text.",
      "type": "info"
    }
  }
}
